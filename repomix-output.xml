.sec-head .h-display{font-size:clamp(1.9rem,3.6vw,3rem);margin-top:16px}
.sec-head p{margin-top:14px}
.sec-link{font-family:var(--ff-en-sans);font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:var(--brown);display:inline-flex;gap:10px;align-items:center;white-space:nowrap;padding-bottom:6px;border-bottom:1px solid var(--gold-line);transition:.3s var(--ease)}
.sec-link:hover{color:var(--gold);border-color:var(--gold)}
.sec-link .arrow{font-family:var(--ff-en-sans)}
[dir="rtl"] .sec-link .arrow{transform:scaleX(-1)}

/* ---------- Categories ---------- */
.cats{background:var(--paper)}
.cat-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:300px;gap:18px}
.cat{
  position:relative;overflow:hidden;border-radius:6px;background:#211a13;
  display:flex;align-items:flex-end;isolation:isolate;
}
.cat:nth-child(1){grid-column:span 2;grid-row:span 2}
.cat img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2;transition:transform 1.1s var(--ease)}
.cat::after{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(to top,rgba(18,13,9,.82) 0%,rgba(18,13,9,.25) 50%,rgba(18,13,9,.05) 100%);transition:.5s var(--ease)}
.cat:hover img{transform:scale(1.07)}
.cat:hover::after{background:linear-gradient(to top,rgba(18,13,9,.88) 0%,rgba(120,90,50,.28) 60%,rgba(18,13,9,.1) 100%)}
.cat-body{padding:26px;color:var(--paper);position:relative;width:100%}
.cat-num{font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.2em;color:var(--gold-soft)}
.cat-title{font-family:var(--ff-ar-display);font-weight:600;font-size:1.5rem;margin:8px 0 4px}
.lang-en .cat-title{font-family:var(--ff-en-serif)}
.cat:nth-child(1) .cat-title{font-size:2.1rem}
.cat-sub{font-size:.92rem;color:rgba(246,241,232,.75)}
.cat-go{margin-top:14px;font-family:var(--ff-en-sans);font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-soft);display:inline-flex;gap:8px;opacity:0;transform:translateY(8px);transition:.4s var(--ease)}
.cat:hover .cat-go{opacity:1;transform:none}

/* ---------- Signature / Editorial ---------- */
.signature{background:var(--ivory);position:relative;overflow:hidden}
.sig-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(40px,6vw,90px);align-items:center}
.sig-visual{position:relative}
.sig-visual .main{border-radius:6px;overflow:hidden;box-shadow:var(--shadow);aspect-ratio:4/5}
.sig-visual .main img{width:100%;height:100%;object-fit:cover}
.sig-visual .badge{
  position:absolute;inset-inline-start:-30px;bottom:40px;background:var(--espresso);color:var(--paper);
  padding:24px 28px;border-radius:6px;box-shadow:var(--shadow);max-width:200px;
}
.sig-visual .badge .num{font-family:var(--ff-en-serif);font-size:2.8rem;color:var(--gold-soft);line-height:1}
.sig-visual .badge .lbl{font-size:.88rem;color:rgba(246,241,232,.78);margin-top:6px}
.sig-text h2{font-size:clamp(2rem,3.6vw,3.1rem);margin:18px 0 22px}
.sig-text>.lead{margin-bottom:34px}
.pillars{display:grid;grid-template-columns:1fr 1fr;gap:26px 30px}
.pillar{border-top:1px solid var(--gold-line);padding-top:16px}
.pillar .pi{width:30px;height:30px;color:var(--gold);margin-bottom:12px}
.pillar .pi svg{width:30px;height:30px;stroke:currentColor;stroke-width:1.4;fill:none}
.pillar h3{font-family:var(--ff-ar-display);font-weight:600;font-size:1.18rem;color:var(--espresso);margin-bottom:6px}
.lang-en .pillar h3{font-family:var(--ff-en-serif)}
.pillar p{font-size:.92rem;color:var(--muted)}

/* ---------- Products ---------- */
.products{background:var(--paper)}
.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.card{background:var(--ivory);border:1px solid var(--line);border-radius:6px;overflow:hidden;transition:.45s var(--ease);position:relative}
.card:hover{transform:translateY(-6px);box-shadow:var(--shadow-soft);border-color:var(--gold-line)}
.card-media{position:relative;aspect-ratio:1/1;overflow:hidden;background:#e7ddcb}
.card-media img{width:100%;height:100%;object-fit:cover;transition:transform 1s var(--ease)}
.card:hover .card-media img{transform:scale(1.06)}
.card-tag{position:absolute;top:14px;inset-inline-start:14px;background:rgba(42,33,26,.9);color:var(--gold-soft);font-family:var(--ff-en-sans);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;padding:5px 11px;border-radius:30px}
.card-fav{position:absolute;top:12px;inset-inline-end:12px;width:36px;height:36px;border-radius:50%;background:rgba(246,241,232,.92);display:grid;place-items:center;color:var(--brown);transition:.3s var(--ease)}
.card-fav:hover{background:var(--gold);color:#fff}
.card-fav svg{width:17px;height:17px;stroke:currentColor;stroke-width:1.5;fill:none}
.quick{
  position:absolute;inset-inline:14px;bottom:14px;background:rgba(246,241,232,.95);backdrop-filter:blur(6px);
  color:var(--espresso);font-size:.86rem;font-weight:500;padding:12px;border-radius:4px;text-align:center;
  opacity:0;transform:translateY(14px);transition:.4s var(--ease);
}
.card:hover .quick{opacity:1;transform:none}
.card-body{padding:20px}
.card-cat{font-family:var(--ff-en-sans);font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.card-name{font-family:var(--ff-ar-display);font-weight:600;font-size:1.25rem;color:var(--espresso);margin:6px 0 4px}
.lang-en .card-name{font-family:var(--ff-en-serif)}
.card-desc{font-size:.84rem;color:var(--muted);min-height:38px}
.card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:14px;padding-top:14px;border-top:1px solid var(--line)}
.price{font-family:var(--ff-en-sans);font-weight:500;color:var(--brown)}
.price b{font-size:1.2rem;color:var(--espresso)}
.price .cur{font-size:.78rem;color:var(--muted)}
.price .old{font-size:.8rem;color:var(--muted);text-decoration:line-through;margin-inline-start:8px}
.add-cart{background:var(--espresso);color:var(--paper);width:42px;height:42px;border-radius:50%;display:grid;place-items:center;transition:.35s var(--ease)}
.add-cart:hover{background:var(--gold);transform:scale(1.08) rotate(90deg)}
.add-cart svg{width:18px;height:18px;stroke:currentColor;stroke-width:1.6;fill:none;transition:transform .35s var(--ease)}
.add-cart:hover svg{transform:rotate(-90deg)}

/* ---------- Day / Night showroom ---------- */
.showroom{background:var(--espresso);color:var(--paper);overflow:hidden;transition:background 1.2s var(--ease)}
.showroom.night{background:#0c0907}
.show-head{display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:26px;margin-bottom:46px}
.show-head .eyebrow{color:var(--gold-soft)}
.show-head .eyebrow::before{background:var(--gold-soft)}
.show-head h2{font-size:clamp(2rem,3.6vw,3.1rem);color:#fff;margin-top:14px}
.show-head p{color:rgba(246,241,232,.7);max-width:46ch;margin-top:12px}

.mode-toggle{display:flex;align-items:center;gap:16px;flex-shrink:0}
.mode-toggle .ml{font-family:var(--ff-en-sans);font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(246,241,232,.55);transition:.4s var(--ease)}
.mode-toggle .ml.on{color:var(--gold-soft)}
.switch{width:74px;height:36px;border-radius:30px;background:linear-gradient(135deg,#cfe1ef,#a9c6dd);position:relative;transition:.6s var(--ease);box-shadow:inset 0 2px 6px rgba(0,0,0,.2)}
.showroom.night .switch{background:linear-gradient(135deg,#241a12,#0e0a07)}
.switch .knob{position:absolute;top:3px;inset-inline-start:3px;width:30px;height:30px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#fff7e0,#f4c969);box-shadow:0 0 14px rgba(244,201,105,.7);transition:.6s var(--ease)}
.showroom.night .switch .knob{inset-inline-start:41px;background:radial-gradient(circle at 35% 30%,#fff3d6,#e0a94a);box-shadow:0 0 26px 6px rgba(224,169,74,.85)}

.room{
  position:relative;border-radius:10px;overflow:hidden;aspect-ratio:16/8;min-height:380px;
  box-shadow:0 40px 90px -40px rgba(0,0,0,.7);
}
.room img.room-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:filter 1.3s var(--ease),transform 1.3s var(--ease)}
/* day grade */
.room .grade-day{position:absolute;inset:0;background:linear-gradient(120deg,rgba(255,244,224,.16),rgba(255,230,190,.05));mix-blend-mode:overlay;transition:opacity 1.3s var(--ease);opacity:1}
/* night darkening */
.room .grade-night{position:absolute;inset:0;background:radial-gradient(120% 120% at 50% 0%,rgba(8,6,4,.35),rgba(6,4,3,.86) 80%);opacity:0;transition:opacity 1.3s var(--ease)}
.showroom.night .room img.room-photo{filter:brightness(.42) saturate(1.05) contrast(1.05)}
.showroom.night .room .grade-day{opacity:0}
.showroom.night .room .grade-night{opacity:1}

/* lamp glows */
.glow{position:absolute;border-radius:50%;opacity:0;transition:opacity 1.4s var(--ease);pointer-events:none;filter:blur(2px)}
.showroom.night .glow{opacity:1}
.glow.lamp-l{width:30%;height:70%;top:-6%;inset-inline-start:6%;background:radial-gradient(circle,rgba(255,201,112,.85) 0%,rgba(255,180,90,.32) 32%,transparent 66%);mix-blend-mode:screen;animation:flick 5s ease-in-out infinite}
.glow.lamp-r{width:26%;height:60%;bottom:-4%;inset-inline-end:9%;background:radial-gradient(circle,rgba(255,196,110,.7) 0%,rgba(240,160,80,.25) 38%,transparent 68%);mix-blend-mode:screen;animation:flick 6.5s ease-in-out infinite}
.glow.center{width:46%;height:46%;top:30%;inset-inline-start:30%;background:radial-gradient(circle,rgba(255,210,140,.35) 0%,transparent 70%);mix-blend-mode:screen}
.glow.floor{width:60%;height:24%;bottom:2%;inset-inline-start:20%;background:radial-gradient(ellipse,rgba(255,190,110,.28) 0%,transparent 72%);mix-blend-mode:screen;filter:blur(10px)}
@keyframes flick{0%,100%{opacity:1}48%{opacity:.86}52%{opacity:.94}70%{opacity:.82}}
.showroom.night .glow.lamp-l,.showroom.night .glow.lamp-r{opacity:1}

/* lamp source dots */
.bulb{position:absolute;width:14px;height:14px;border-radius:50%;background:#fff6df;box-shadow:0 0 24px 10px rgba(255,205,120,.9);opacity:0;transition:opacity 1.4s var(--ease)}
.showroom.night .bulb{opacity:1}
.bulb.b1{top:18%;inset-inline-start:13%}
.bulb.b2{bottom:24%;inset-inline-end:16%}

.room-caption{position:absolute;bottom:0;inset-inline:0;padding:30px clamp(20px,4vw,44px);z-index:4;display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:18px;background:linear-gradient(to top,rgba(6,4,3,.7),transparent)}
.room-caption .rc-name{font-family:var(--ff-ar-display);font-weight:600;font-size:1.6rem;color:#fff}
.lang-en .room-caption .rc-name{font-family:var(--ff-en-serif)}
.room-caption .rc-sub{font-size:.9rem;color:rgba(246,241,232,.78);margin-top:4px}
.room-caption .rc-tag{font-family:var(--ff-en-sans);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold-soft);background:rgba(182,138,78,.16);border:1px solid var(--gold-line);padding:8px 16px;border-radius:30px}
.show-note{margin-top:22px;font-size:.88rem;color:rgba(246,241,232,.5);text-align:center}

/* ---------- Collections ---------- */
.collections{background:var(--ivory)}
.coll-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.coll{position:relative;border-radius:6px;overflow:hidden;min-height:480px;display:flex;align-items:flex-end;isolation:isolate}
.coll img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2;transition:transform 1.2s var(--ease)}
.coll::after{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(to top,rgba(18,13,9,.78),rgba(18,13,9,.1) 60%,transparent);transition:.5s var(--ease)}
.coll:hover img{transform:scale(1.06)}
.coll-body{padding:34px;color:var(--paper);width:100%}
.coll-idx{font-family:var(--ff-en-serif);font-style:italic;font-size:1rem;color:var(--gold-soft)}
.coll-title{font-family:var(--ff-ar-display);font-weight:700;font-size:1.9rem;margin:10px 0 8px}
.lang-en .coll-title{font-family:var(--ff-en-serif);font-weight:500}
.coll-sub{font-size:.92rem;color:rgba(246,241,232,.78);max-width:30ch}
.coll-link{margin-top:18px;display:inline-flex;gap:10px;align-items:center;font-family:var(--ff-en-sans);font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:#fff;padding-bottom:6px;border-bottom:1px solid rgba(246,241,232,.4);transition:.3s var(--ease)}
.coll-link:hover{color:var(--gold-soft);border-color:var(--gold-soft)}

/* ---------- Branches ---------- */
.branches{background:var(--espresso);color:var(--paper);position:relative;overflow:hidden}
.branches::before{content:"";position:absolute;inset:0;background:radial-gradient(80% 120% at 85% 10%,rgba(182,138,78,.16),transparent 60%)}
.br-inner{position:relative;display:grid;grid-template-columns:1fr 1.1fr;gap:clamp(40px,6vw,80px);align-items:center}
.br-text .eyebrow{color:var(--gold-soft)}
.br-text .eyebrow::before{background:var(--gold-soft)}
.br-text h2{font-size:clamp(2rem,3.6vw,3.1rem);color:#fff;margin:16px 0 20px}
.br-text p{color:rgba(246,241,232,.74);max-width:46ch;margin-bottom:32px}
.br-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.br-card{background:rgba(246,241,232,.05);border:1px solid rgba(246,241,232,.12);border-radius:6px;padding:24px;transition:.4s var(--ease)}
.br-card:hover{background:rgba(182,138,78,.12);border-color:var(--gold-line);transform:translateY(-4px)}
.br-city{font-family:var(--ff-ar-display);font-weight:600;font-size:1.3rem;color:#fff;display:flex;align-items:center;gap:10px}
.lang-en .br-city{font-family:var(--ff-en-serif)}
.br-city .pin{color:var(--gold-soft)}
.br-city .pin svg{width:18px;height:18px;stroke:currentColor;stroke-width:1.5;fill:none}
.br-addr{font-size:.88rem;color:rgba(246,241,232,.66);margin:10px 0 14px}
.br-hours{font-family:var(--ff-en-sans);font-size:.72rem;letter-spacing:.08em;color:var(--gold-soft)}

/* ---------- Footer ---------- */
.footer{background:var(--ink);color:var(--sand)}
.foot-top{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.5fr;gap:48px;padding-block:clamp(60px,7vw,90px)}
.foot-brand .mark{font-family:var(--ff-en-serif);font-weight:600;font-size:2.2rem;color:#fff}
.foot-brand .mark b{color:var(--gold)}
.foot-brand .ar{font-family:var(--ff-ar-display);letter-spacing:.2em;color:var(--gold-soft);margin-top:2px}
.foot-statement{margin-top:18px;color:rgba(246,241,232,.6);font-size:.94rem;max-width:36ch;line-height:1.8}
.foot-col h4{font-family:var(--ff-ar-display);font-weight:600;color:#fff;font-size:1.05rem;margin-bottom:18px}
.lang-en .foot-col h4{font-family:var(--ff-en-serif)}
.foot-col a,.foot-col li{display:block;color:rgba(246,241,232,.6);font-size:.92rem;padding-block:7px;transition:.3s var(--ease)}
.foot-col a:hover{color:var(--gold-soft);padding-inline-start:6px}
.news p{color:rgba(246,241,232,.6);font-size:.92rem;margin-bottom:18px}
.news-form{display:flex;border:1px solid rgba(246,241,232,.2);border-radius:4px;overflow:hidden;background:rgba(246,241,232,.04)}
.news-form input{flex:1;background:none;border:none;outline:none;color:var(--paper);padding:14px 16px;font-family:inherit;font-size:.9rem}
.news-form input::placeholder{color:rgba(246,241,232,.4)}
.news-form button{background:var(--gold);color:#fff;padding:0 22px;font-weight:500;transition:.3s var(--ease)}
.news-form button:hover{background:var(--gold-soft);color:var(--ink)}
.news-ok{color:var(--gold-soft);font-size:.85rem;margin-top:10px;height:18px}
.socials{display:flex;gap:10px;margin-top:24px}
.socials a{width:40px;height:40px;border:1px solid rgba(246,241,232,.2);border-radius:50%;display:grid;place-items:center;font-family:var(--ff-en-sans);font-size:.72rem;letter-spacing:.05em;color:rgba(246,241,232,.7);transition:.3s var(--ease)}
.socials a:hover{background:var(--gold);border-color:var(--gold);color:#fff}
.foot-bottom{border-top:1px solid rgba(246,241,232,.1);padding-block:24px;display:flex;flex-wrap:wrap;justify-content:space-between;gap:14px;font-family:var(--ff-en-sans);font-size:.78rem;color:rgba(246,241,232,.45);letter-spacing:.04em}
.foot-bottom .pay{display:flex;gap:14px}

/* ---------- Mobile nav ---------- */
.mobile-nav{position:fixed;inset:0;z-index:80;background:var(--espresso);color:var(--paper);padding:90px clamp(24px,7vw,50px) 40px;transform:translateX(100%);transition:transform .5s var(--ease);display:flex;flex-direction:column;gap:6px;overflow-y:auto}
[dir="ltr"] .mobile-nav{transform:translateX(-100%)}
.mobile-nav.open{transform:none}
.mobile-nav a{font-family:var(--ff-ar-display);font-weight:600;font-size:1.6rem;padding-block:14px;border-bottom:1px solid rgba(246,241,232,.1);transition:.3s var(--ease)}
.lang-en .mobile-nav a{font-family:var(--ff-en-serif)}
.mobile-nav a:hover{color:var(--gold-soft)}
.mn-close{position:absolute;top:24px;inset-inline-end:24px;width:46px;height:46px;color:var(--paper);font-size:1.5rem}
.mn-cta{margin-top:24px}

/* ---------- Overlays ---------- */
.overlay{position:fixed;inset:0;z-index:90;background:rgba(22,17,12,.6);backdrop-filter:blur(6px);opacity:0;visibility:hidden;transition:.4s var(--ease)}
.overlay.open{opacity:1;visibility:visible}
.search-panel{position:fixed;top:0;inset-inline:0;z-index:95;background:var(--paper);transform:translateY(-100%);transition:transform .5s var(--ease);padding:40px clamp(20px,6vw,80px)}
.search-panel.open{transform:none}
.search-panel .sp-row{display:flex;align-items:center;gap:18px;max-width:var(--wrap);margin-inline:auto;border-bottom:2px solid var(--espresso);padding-bottom:16px}
.search-panel input{flex:1;border:none;outline:none;background:none;font-family:var(--ff-ar-display);font-size:clamp(1.4rem,3vw,2.2rem);color:var(--espresso)}
.search-panel input::placeholder{color:var(--sand-deep)}
.search-panel .sp-close{font-size:1.6rem;color:var(--brown)}
.sp-tags{max-width:var(--wrap);margin:22px auto 0;display:flex;flex-wrap:wrap;gap:10px}
.sp-tags span{font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;margin-inline-end:6px}
.sp-tags a{padding:8px 16px;border:1px solid var(--line);border-radius:30px;font-size:.86rem;color:var(--brown);transition:.3s var(--ease)}
.sp-tags a:hover{background:var(--espresso);color:var(--paper);border-color:var(--espresso)}

.modal{position:fixed;z-index:100;inset:0;display:grid;place-items:center;padding:24px;opacity:0;visibility:hidden;transition:.4s var(--ease)}
.modal.open{opacity:1;visibility:visible}
.modal-box{background:var(--paper);border-radius:8px;max-width:880px;width:100%;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;box-shadow:var(--shadow);transform:translateY(20px);transition:.4s var(--ease)}
.modal.open .modal-box{transform:none}
.modal-img{aspect-ratio:1/1;background:#e7ddcb}
.modal-img img{width:100%;height:100%;object-fit:cover}
.modal-info{padding:40px;position:relative}
.modal-close{position:absolute;top:18px;inset-inline-end:18px;width:40px;height:40px;border-radius:50%;background:var(--ivory);color:var(--brown);display:grid;place-items:center;font-size:1.2rem;transition:.3s var(--ease)}
.modal-close:hover{background:var(--espresso);color:var(--paper)}
.modal-info .m-cat{font-family:var(--ff-en-sans);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.modal-info h3{font-family:var(--ff-ar-display);font-weight:700;font-size:2rem;color:var(--espresso);margin:8px 0 6px}
.lang-en .modal-info h3{font-family:var(--ff-en-serif)}
.modal-info .m-price{font-family:var(--ff-en-sans);font-size:1.5rem;color:var(--espresso);margin:14px 0}
.modal-info .m-desc{color:var(--muted);font-size:.94rem;margin-bottom:22px}
.m-opts{margin-bottom:26px}
.m-opts .lbl{font-size:.8rem;color:var(--muted);margin-bottom:10px}
.swatches{display:flex;gap:10px}
.swatch{width:30px;height:30px;border-radius:50%;border:2px solid transparent;outline:1px solid var(--line);cursor:pointer;transition:.3s var(--ease)}
.swatch.sel{border-color:var(--gold)}
.toast{position:fixed;bottom:30px;inset-inline-start:50%;transform:translate(-50%,30px);z-index:120;background:var(--espresso);color:var(--paper);padding:14px 26px;border-radius:40px;font-size:.9rem;box-shadow:var(--shadow);opacity:0;visibility:hidden;transition:.4s var(--ease);display:flex;align-items:center;gap:10px}
.toast .tdot{color:var(--gold-soft)}
.toast.show{opacity:1;visibility:visible;transform:translate(-50%,0)}

/* ---------- Responsive ---------- */
@media(max-width:1080px){
