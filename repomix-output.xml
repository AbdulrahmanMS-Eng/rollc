a{color:inherit;text-decoration:none}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
ul{list-style:none}

::selection{background:var(--gold);color:#fff}

/* ---------- Reusable ---------- */
.wrap{max-width:var(--wrap);margin-inline:auto;padding-inline:clamp(20px,5vw,64px)}
.section{padding-block:clamp(72px,9vw,140px);position:relative}
.eyebrow{
  font-family:var(--ff-en-sans);
  font-size:.72rem;letter-spacing:.42em;text-transform:uppercase;
  color:var(--gold);font-weight:500;display:inline-flex;align-items:center;gap:14px;
}
.eyebrow::before{content:"";width:34px;height:1px;background:var(--gold)}
.h-display{
  font-family:var(--ff-ar-display);font-weight:600;line-height:1.18;
  color:var(--espresso);letter-spacing:-.01em;
}
.lang-en .h-display{font-family:var(--ff-en-serif);font-weight:500;letter-spacing:0}
.lead{color:var(--muted);font-size:clamp(1rem,1.1vw,1.12rem);max-width:54ch}
.gold-text{color:var(--gold)}

.btn{
  display:inline-flex;align-items:center;justify-content:center;gap:12px;
  padding:16px 34px;font-size:.95rem;font-weight:500;letter-spacing:.02em;
  border-radius:var(--r);transition:.4s var(--ease);position:relative;overflow:hidden;
}
.btn--solid{background:var(--espresso);color:var(--paper)}
.btn--solid:hover{background:var(--gold);transform:translateY(-2px)}
.btn--solid:hover .btn-ar{transform:translateX(0)}
.btn--ghost{border:1px solid rgba(247,243,236,.5);color:var(--paper)}
.btn--ghost:hover{background:rgba(247,243,236,.12);border-color:var(--paper)}
.btn--outline{border:1px solid var(--espresso);color:var(--espresso)}
.btn--outline:hover{background:var(--espresso);color:var(--paper);transform:translateY(-2px)}
.btn .arrow{transition:transform .4s var(--ease);font-family:var(--ff-en-sans)}
[dir="rtl"] .btn .arrow{transform:scaleX(-1)}
.btn:hover .arrow{transform:translateX(-4px) scaleX(1)}
[dir="rtl"] .btn:hover .arrow{transform:translateX(4px) scaleX(-1)}

/* ---------- Header ---------- */
.topbar{
  background:var(--espresso);color:var(--sand);font-family:var(--ff-en-sans);
  font-size:.74rem;letter-spacing:.12em;text-align:center;padding:9px 16px;
}
.topbar span{opacity:.85}
.topbar b{color:var(--gold-soft);font-weight:500}

.header{
  position:sticky;top:0;z-index:60;
  background:rgba(246,241,232,.82);backdrop-filter:blur(16px);
  border-bottom:1px solid transparent;transition:.4s var(--ease);
}
.header.scrolled{background:rgba(246,241,232,.96);border-bottom-color:var(--line);box-shadow:0 8px 30px -22px rgba(42,33,26,.5)}
.nav{display:flex;align-items:center;justify-content:space-between;gap:24px;height:84px}
.header.scrolled .nav{height:70px}
.nav{transition:height .4s var(--ease)}

.brand{display:flex;flex-direction:column;line-height:1;flex-shrink:0}
.brand .mark{font-family:var(--ff-en-serif);font-weight:600;font-size:1.9rem;letter-spacing:.02em;color:var(--espresso)}
.brand .mark b{color:var(--gold)}
.brand .ar{font-family:var(--ff-ar-display);font-size:1.05rem;color:var(--brown);letter-spacing:.18em;margin-top:2px}

.menu{display:flex;align-items:center;gap:34px}
.menu a{
  font-size:.96rem;color:var(--brown);position:relative;padding-block:6px;
  transition:color .3s var(--ease);
}
.lang-en .menu a{font-family:var(--ff-en-sans);font-size:.86rem;letter-spacing:.06em;text-transform:uppercase}
.menu a::after{
  content:"";position:absolute;inset-inline:0;bottom:0;height:1px;background:var(--gold);
  transform:scaleX(0);transform-origin:center;transition:transform .35s var(--ease);
}
.menu a:hover{color:var(--gold)}
.menu a:hover::after{transform:scaleX(1)}

.actions{display:flex;align-items:center;gap:8px}
.icon-btn{
  width:42px;height:42px;border-radius:50%;display:grid;place-items:center;
  color:var(--brown);transition:.3s var(--ease);position:relative;
}
.icon-btn:hover{background:rgba(182,138,78,.12);color:var(--gold)}
.icon-btn svg{width:20px;height:20px;stroke:currentColor;stroke-width:1.5;fill:none}
.cart-count{
  position:absolute;top:4px;inset-inline-end:4px;background:var(--gold);color:#fff;
  font-size:.62rem;font-family:var(--ff-en-sans);min-width:16px;height:16px;border-radius:9px;
  display:grid;place-items:center;padding:0 4px;transition:transform .3s var(--ease);
}
.cart-count.pop{animation:pop .4s var(--ease)}
@keyframes pop{0%{transform:scale(1)}45%{transform:scale(1.5)}100%{transform:scale(1)}}

.lang-switch{
  display:flex;align-items:center;border:1px solid var(--line);border-radius:30px;
  font-family:var(--ff-en-sans);font-size:.74rem;overflow:hidden;
}
.lang-switch button{padding:7px 13px;color:var(--muted);transition:.3s var(--ease)}
.lang-switch button.active{background:var(--espresso);color:var(--paper)}

.cta-shop{
  background:var(--gold);color:#fff;padding:12px 26px;border-radius:var(--r);font-weight:500;
  font-size:.92rem;transition:.4s var(--ease);white-space:nowrap;
}
.cta-shop:hover{background:var(--espresso);transform:translateY(-2px);box-shadow:0 14px 28px -14px rgba(182,138,78,.6)}

.burger{display:none;flex-direction:column;gap:5px;width:42px;height:42px;align-items:center;justify-content:center}
.burger span{width:22px;height:1.6px;background:var(--brown);transition:.3s var(--ease)}
.burger.open span:nth-child(1){transform:translateY(6.6px) rotate(45deg)}
.burger.open span:nth-child(2){opacity:0}
.burger.open span:nth-child(3){transform:translateY(-6.6px) rotate(-45deg)}

/* ---------- Hero ---------- */
.hero{
  position:relative;min-height:calc(100vh - 84px);display:flex;align-items:center;
  overflow:hidden;background:#1c1610;
}
.hero-bg{position:absolute;inset:0;z-index:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;transform:scale(1.12);animation:heroZoom 12s var(--ease) forwards}
@keyframes heroZoom{to{transform:scale(1)}}
.hero-bg::after{
  content:"";position:absolute;inset:0;
  background:linear-gradient(to inline-start,rgba(20,16,12,.86) 0%,rgba(20,16,12,.55) 42%,rgba(20,16,12,.15) 75%,transparent 100%);
}
[dir="ltr"] .hero-bg::after{background:linear-gradient(to inline-start,transparent 0%,rgba(20,16,12,.2) 30%,rgba(20,16,12,.6) 65%,rgba(20,16,12,.88) 100%)}
.hero-inner{position:relative;z-index:2;color:var(--paper);max-width:660px;padding-block:60px}
.hero .eyebrow{color:var(--gold-soft)}
.hero .eyebrow::before{background:var(--gold-soft)}
.hero h1{
  font-family:var(--ff-ar-display);font-weight:700;color:#fff;
  font-size:clamp(2.6rem,6vw,5rem);line-height:1.12;margin:22px 0 24px;letter-spacing:-.01em;
}
.lang-en .hero h1{font-family:var(--ff-en-serif);font-weight:500}
.hero h1 em{font-style:normal;color:var(--gold-soft)}
.hero p{font-size:clamp(1rem,1.3vw,1.18rem);color:rgba(246,241,232,.82);max-width:50ch;margin-bottom:38px}
.hero-cta{display:flex;flex-wrap:wrap;gap:16px}

.hero-card{
  position:absolute;z-index:3;inset-inline-end:clamp(20px,5vw,64px);bottom:46px;
  width:268px;background:rgba(246,241,232,.95);backdrop-filter:blur(8px);
  border-radius:6px;padding:18px;box-shadow:var(--shadow);
  display:flex;gap:14px;align-items:center;opacity:0;animation:fadeUp 1s var(--ease) 1s forwards;
}
.hero-card img{width:70px;height:70px;object-fit:cover;border-radius:4px;flex-shrink:0}
.hero-card .hc-tag{font-family:var(--ff-en-sans);font-size:.66rem;letter-spacing:.22em;color:var(--gold);text-transform:uppercase}
.hero-card .hc-name{font-family:var(--ff-ar-display);font-weight:600;color:var(--espresso);font-size:1.05rem;margin:3px 0 4px}
.hero-card .hc-price{font-family:var(--ff-en-sans);font-size:.9rem;color:var(--brown)}
.hero-scroll{
  position:absolute;bottom:30px;inset-inline-start:50%;transform:translateX(-50%);z-index:3;
  color:rgba(246,241,232,.7);font-family:var(--ff-en-sans);font-size:.66rem;letter-spacing:.3em;
  text-transform:uppercase;display:flex;flex-direction:column;align-items:center;gap:10px;
}
.hero-scroll .line{width:1px;height:42px;background:linear-gradient(rgba(246,241,232,.7),transparent);animation:scrollLine 2s var(--ease) infinite}
@keyframes scrollLine{0%,100%{opacity:.3;transform:scaleY(.6)}50%{opacity:1;transform:scaleY(1)}}

/* fade animations */
.reveal{opacity:0;transform:translateY(34px);transition:opacity 1s var(--ease),transform 1s var(--ease)}
.reveal.in{opacity:1;transform:none}
@keyframes fadeUp{to{opacity:1;transform:translateY(0)}}

/* ---------- Section head ---------- */
.sec-head{display:flex;align-items:flex-end;justify-content:space-between;gap:30px;margin-bottom:clamp(40px,5vw,64px)}
.sec-head .h-display{font-size:clamp(1.9rem,3.6vw,3rem);margin-top:16px}
.sec-head p{margin-top:14px}
.sec-link{font-family:var(--ff-en-sans);font-size:.82rem;letter-spacing:.14em;text-transform:uppercase;color:var(--brown);display:inline-flex;gap:10px;align-items:center;white-space:nowrap;padding-bottom:6px;border-bottom:1px solid var(--gold-line);transition:.3s var(--ease)}
.sec-link:hover{color:var(--gold);border-color:var(--gold)}
.sec-link .arrow{font-family:var(--ff-en-sans)}
[dir="rtl"] .sec-link .arrow{transform:scaleX(-1)}

/* ---------- Categories ---------- */
.cats{background:var(--paper)}
.cat-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:300px;gap:18px}
.cat{
  position:relative;overflow:hidden;border-radius:6px;background:#211a13;
  display:flex;align-items:flex-end;isolation:isolate;
}
.cat:nth-child(1){grid-column:span 2;grid-row:span 2}
.cat img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2;transition:transform 1.1s var(--ease)}
.cat::after{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(to top,rgba(18,13,9,.82) 0%,rgba(18,13,9,.25) 50%,rgba(18,13,9,.05) 100%);transition:.5s var(--ease)}
.cat:hover img{transform:scale(1.07)}
.cat:hover::after{background:linear-gradient(to top,rgba(18,13,9,.88) 0%,rgba(120,90,50,.28) 60%,rgba(18,13,9,.1) 100%)}
.cat-body{padding:26px;color:var(--paper);position:relative;width:100%}
.cat-num{font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.2em;color:var(--gold-soft)}
.cat-title{font-family:var(--ff-ar-display);font-weight:600;font-size:1.5rem;margin:8px 0 4px}
.lang-en .cat-title{font-family:var(--ff-en-serif)}
.cat:nth-child(1) .cat-title{font-size:2.1rem}
.cat-sub{font-size:.92rem;color:rgba(246,241,232,.75)}
.cat-go{margin-top:14px;font-family:var(--ff-en-sans);font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-soft);display:inline-flex;gap:8px;opacity:0;transform:translateY(8px);transition:.4s var(--ease)}
.cat:hover .cat-go{opacity:1;transform:none}

/* ---------- Signature / Editorial ---------- */
.signature{background:var(--ivory);position:relative;overflow:hidden}
.sig-grid{display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(40px,6vw,90px);align-items:center}
.sig-visual{position:relative}
.sig-visual .main{border-radius:6px;overflow:hidden;box-shadow:var(--shadow);aspect-ratio:4/5}
.sig-visual .main img{width:100%;height:100%;object-fit:cover}
.sig-visual .badge{
  position:absolute;inset-inline-start:-30px;bottom:40px;background:var(--espresso);color:var(--paper);
  padding:24px 28px;border-radius:6px;box-shadow:var(--shadow);max-width:200px;
}
.sig-visual .badge .num{font-family:var(--ff-en-serif);font-size:2.8rem;color:var(--gold-soft);line-height:1}
.sig-visual .badge .lbl{font-size:.88rem;color:rgba(246,241,232,.78);margin-top:6px}
.sig-text h2{font-size:clamp(2rem,3.6vw,3.1rem);margin:18px 0 22px}
.sig-text>.lead{margin-bottom:34px}
.pillars{display:grid;grid-template-columns:1fr 1fr;gap:26px 30px}
.pillar{border-top:1px solid var(--gold-line);padding-top:16px}
.pillar .pi{width:30px;height:30px;color:var(--gold);margin-bottom:12px}
.pillar .pi svg{width:30px;height:30px;stroke:currentColor;stroke-width:1.4;fill:none}
.pillar h3{font-family:var(--ff-ar-display);font-weight:600;font-size:1.18rem;color:var(--espresso);margin-bottom:6px}
.lang-en .pillar h3{font-family:var(--ff-en-serif)}
.pillar p{font-size:.92rem;color:var(--muted)}

/* ---------- Products ---------- */
.products{background:var(--paper)}
.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.card{background:var(--ivory);border:1px solid var(--line);border-radius:6px;overflow:hidden;transition:.45s var(--ease);position:relative}
.card:hover{transform:translateY(-6px);box-shadow:var(--shadow-soft);border-color:var(--gold-line)}
.card-media{position:relative;aspect-ratio:1/1;overflow:hidden;background:#e7ddcb}
.card-media img{width:100%;height:100%;object-fit:cover;transition:transform 1s var(--ease)}
.card:hover .card-media img{transform:scale(1.06)}
.card-tag{position:absolute;top:14px;inset-inline-start:14px;background:rgba(42,33,26,.9);color:var(--gold-soft);font-family:var(--ff-en-sans);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;padding:5px 11px;border-radius:30px}
.card-fav{position:absolute;top:12px;inset-inline-end:12px;width:36px;height:36px;border-radius:50%;background:rgba(246,241,232,.92);display:grid;place-items:center;color:var(--brown);transition:.3s var(--ease)}
.card-fav:hover{background:var(--gold);color:#fff}
.card-fav svg{width:17px;height:17px;stroke:currentColor;stroke-width:1.5;fill:none}
.quick{
  position:absolute;inset-inline:14px;bottom:14px;background:rgba(246,241,232,.95);backdrop-filter:blur(6px);
  color:var(--espresso);font-size:.86rem;font-weight:500;padding:12px;border-radius:4px;text-align:center;
  opacity:0;transform:translateY(14px);transition:.4s var(--ease);
}
.card:hover .quick{opacity:1;transform:none}
.card-body{padding:20px}
.card-cat{font-family:var(--ff-en-sans);font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.card-name{font-family:var(--ff-ar-display);font-weight:600;font-size:1.25rem;color:var(--espresso);margin:6px 0 4px}
.lang-en .card-name{font-family:var(--ff-en-serif)}
.card-desc{font-size:.84rem;color:var(--muted);min-height:38px}
.card-foot{display:flex;align-items:center;justify-content:space-between;margin-top:14px;padding-top:14px;border-top:1px solid var(--line)}
.price{font-family:var(--ff-en-sans);font-weight:500;color:var(--brown)}
.price b{font-size:1.2rem;color:var(--espresso)}
.price .cur{font-size:.78rem;color:var(--muted)}
.price .old{font-size:.8rem;color:var(--muted);text-decoration:line-through;margin-inline-start:8px}
.add-cart{background:var(--espresso);color:var(--paper);width:42px;height:42px;border-radius:50%;display:grid;place-items:center;transition:.35s var(--ease)}
.add-cart:hover{background:var(--gold);transform:scale(1.08) rotate(90deg)}
.add-cart svg{width:18px;height:18px;stroke:currentColor;stroke-width:1.6;fill:none;transition:transform .35s var(--ease)}
.add-cart:hover svg{transform:rotate(-90deg)}

/* ---------- Day / Night showroom ---------- */
.showroom{background:var(--espresso);color:var(--paper);overflow:hidden;transition:background 1.2s var(--ease)}
.showroom.night{background:#0c0907}
.show-head{display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:26px;margin-bottom:46px}
.show-head .eyebrow{color:var(--gold-soft)}
.show-head .eyebrow::before{background:var(--gold-soft)}
.show-head h2{font-size:clamp(2rem,3.6vw,3.1rem);color:#fff;margin-top:14px}
.show-head p{color:rgba(246,241,232,.7);max-width:46ch;margin-top:12px}

.mode-toggle{display:flex;align-items:center;gap:16px;flex-shrink:0}
.mode-toggle .ml{font-family:var(--ff-en-sans);font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(246,241,232,.55);transition:.4s var(--ease)}
.mode-toggle .ml.on{color:var(--gold-soft)}
.switch{width:74px;height:36px;border-radius:30px;background:linear-gradient(135deg,#cfe1ef,#a9c6dd);position:relative;transition:.6s var(--ease);box-shadow:inset 0 2px 6px rgba(0,0,0,.2)}
.showroom.night .switch{background:linear-gradient(135deg,#241a12,#0e0a07)}
.switch .knob{position:absolute;top:3px;inset-inline-start:3px;width:30px;height:30px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#fff7e0,#f4c969);box-shadow:0 0 14px rgba(244,201,105,.7);transition:.6s var(--ease)}
.showroom.night .switch .knob{inset-inline-start:41px;background:radial-gradient(circle at 35% 30%,#fff3d6,#e0a94a);box-shadow:0 0 26px 6px rgba(224,169,74,.85)}

.room{
  position:relative;border-radius:10px;overflow:hidden;aspect-ratio:16/8;min-height:380px;
  box-shadow:0 40px 90px -40px rgba(0,0,0,.7);
}
.room img.room-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:filter 1.3s var(--ease),transform 1.3s var(--ease)}
/* day grade */
.room .grade-day{position:absolute;inset:0;background:linear-gradient(120deg,rgba(255,244,224,.16),rgba(255,230,190,.05));mix-blend-mode:overlay;transition:opacity 1.3s var(--ease);opacity:1}
/* night darkening */
.room .grade-night{position:absolute;inset:0;background:radial-gradient(120% 120% at 50% 0%,rgba(8,6,4,.35),rgba(6,4,3,.86) 80%);opacity:0;transition:opacity 1.3s var(--ease)}
.showroom.night .room img.room-photo{filter:brightness(.42) saturate(1.05) contrast(1.05)}
.showroom.night .room .grade-day{opacity:0}
.showroom.night .room .grade-night{opacity:1}

/* lamp glows */
.glow{position:absolute;border-radius:50%;opacity:0;transition:opacity 1.4s var(--ease);pointer-events:none;filter:blur(2px)}
.showroom.night .glow{opacity:1}
.glow.lamp-l{width:30%;height:70%;top:-6%;inset-inline-start:6%;background:radial-gradient(circle,rgba(255,201,112,.85) 0%,rgba(255,180,90,.32) 32%,transparent 66%);mix-blend-mode:screen;animation:flick 5s ease-in-out infinite}
.glow.lamp-r{width:26%;height:60%;bottom:-4%;inset-inline-end:9%;background:radial-gradient(circle,rgba(255,196,110,.7) 0%,rgba(240,160,80,.25) 38%,transparent 68%);mix-blend-mode:screen;animation:flick 6.5s ease-in-out infinite}
.glow.center{width:46%;height:46%;top:30%;inset-inline-start:30%;background:radial-gradient(circle,rgba(255,210,140,.35) 0%,transparent 70%);mix-blend-mode:screen}
.glow.floor{width:60%;height:24%;bottom:2%;inset-inline-start:20%;background:radial-gradient(ellipse,rgba(255,190,110,.28) 0%,transparent 72%);mix-blend-mode:screen;filter:blur(10px)}
@keyframes flick{0%,100%{opacity:1}48%{opacity:.86}52%{opacity:.94}70%{opacity:.82}}
.showroom.night .glow.lamp-l,.showroom.night .glow.lamp-r{opacity:1}

/* lamp source dots */
.bulb{position:absolute;width:14px;height:14px;border-radius:50%;background:#fff6df;box-shadow:0 0 24px 10px rgba(255,205,120,.9);opacity:0;transition:opacity 1.4s var(--ease)}
.showroom.night .bulb{opacity:1}
.bulb.b1{top:18%;inset-inline-start:13%}
.bulb.b2{bottom:24%;inset-inline-end:16%}

.room-caption{position:absolute;bottom:0;inset-inline:0;padding:30px clamp(20px,4vw,44px);z-index:4;display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:18px;background:linear-gradient(to top,rgba(6,4,3,.7),transparent)}
.room-caption .rc-name{font-family:var(--ff-ar-display);font-weight:600;font-size:1.6rem;color:#fff}
.lang-en .room-caption .rc-name{font-family:var(--ff-en-serif)}
.room-caption .rc-sub{font-size:.9rem;color:rgba(246,241,232,.78);margin-top:4px}
.room-caption .rc-tag{font-family:var(--ff-en-sans);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold-soft);background:rgba(182,138,78,.16);border:1px solid var(--gold-line);padding:8px 16px;border-radius:30px}
.show-note{margin-top:22px;font-size:.88rem;color:rgba(246,241,232,.5);text-align:center}

/* ---------- Collections ---------- */
.collections{background:var(--ivory)}
.coll-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.coll{position:relative;border-radius:6px;overflow:hidden;min-height:480px;display:flex;align-items:flex-end;isolation:isolate}
.coll img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-2;transition:transform 1.2s var(--ease)}
.coll::after{content:"";position:absolute;inset:0;z-index:-1;background:linear-gradient(to top,rgba(18,13,9,.78),rgba(18,13,9,.1) 60%,transparent);transition:.5s var(--ease)}
.coll:hover img{transform:scale(1.06)}
.coll-body{padding:34px;color:var(--paper);width:100%}
.coll-idx{font-family:var(--ff-en-serif);font-style:italic;font-size:1rem;color:var(--gold-soft)}
.coll-title{font-family:var(--ff-ar-display);font-weight:700;font-size:1.9rem;margin:10px 0 8px}
.lang-en .coll-title{font-family:var(--ff-en-serif);font-weight:500}
.coll-sub{font-size:.92rem;color:rgba(246,241,232,.78);max-width:30ch}
.coll-link{margin-top:18px;display:inline-flex;gap:10px;align-items:center;font-family:var(--ff-en-sans);font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:#fff;padding-bottom:6px;border-bottom:1px solid rgba(246,241,232,.4);transition:.3s var(--ease)}
.coll-link:hover{color:var(--gold-soft);border-color:var(--gold-soft)}

/* ---------- Branches ---------- */
.branches{background:var(--espresso);color:var(--paper);position:relative;overflow:hidden}
.branches::before{content:"";position:absolute;inset:0;background:radial-gradient(80% 120% at 85% 10%,rgba(182,138,78,.16),transparent 60%)}
.br-inner{position:relative;display:grid;grid-template-columns:1fr 1.1fr;gap:clamp(40px,6vw,80px);align-items:center}
.br-text .eyebrow{color:var(--gold-soft)}
.br-text .eyebrow::before{background:var(--gold-soft)}
.br-text h2{font-size:clamp(2rem,3.6vw,3.1rem);color:#fff;margin:16px 0 20px}
.br-text p{color:rgba(246,241,232,.74);max-width:46ch;margin-bottom:32px}
.br-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.br-card{background:rgba(246,241,232,.05);border:1px solid rgba(246,241,232,.12);border-radius:6px;padding:24px;transition:.4s var(--ease)}
.br-card:hover{background:rgba(182,138,78,.12);border-color:var(--gold-line);transform:translateY(-4px)}
.br-city{font-family:var(--ff-ar-display);font-weight:600;font-size:1.3rem;color:#fff;display:flex;align-items:center;gap:10px}
.lang-en .br-city{font-family:var(--ff-en-serif)}
.br-city .pin{color:var(--gold-soft)}
.br-city .pin svg{width:18px;height:18px;stroke:currentColor;stroke-width:1.5;fill:none}
.br-addr{font-size:.88rem;color:rgba(246,241,232,.66);margin:10px 0 14px}
.br-hours{font-family:var(--ff-en-sans);font-size:.72rem;letter-spacing:.08em;color:var(--gold-soft)}

/* ---------- Footer ---------- */
.footer{background:var(--ink);color:var(--sand)}
.foot-top{display:grid;grid-template-columns:1.4fr 1fr 1fr 1.5fr;gap:48px;padding-block:clamp(60px,7vw,90px)}
.foot-brand .mark{font-family:var(--ff-en-serif);font-weight:600;font-size:2.2rem;color:#fff}
.foot-brand .mark b{color:var(--gold)}
.foot-brand .ar{font-family:var(--ff-ar-display);letter-spacing:.2em;color:var(--gold-soft);margin-top:2px}
.foot-statement{margin-top:18px;color:rgba(246,241,232,.6);font-size:.94rem;max-width:36ch;line-height:1.8}
.foot-col h4{font-family:var(--ff-ar-display);font-weight:600;color:#fff;font-size:1.05rem;margin-bottom:18px}
.lang-en .foot-col h4{font-family:var(--ff-en-serif)}
.foot-col a,.foot-col li{display:block;color:rgba(246,241,232,.6);font-size:.92rem;padding-block:7px;transition:.3s var(--ease)}
.foot-col a:hover{color:var(--gold-soft);padding-inline-start:6px}
.news p{color:rgba(246,241,232,.6);font-size:.92rem;margin-bottom:18px}
.news-form{display:flex;border:1px solid rgba(246,241,232,.2);border-radius:4px;overflow:hidden;background:rgba(246,241,232,.04)}
.news-form input{flex:1;background:none;border:none;outline:none;color:var(--paper);padding:14px 16px;font-family:inherit;font-size:.9rem}
.news-form input::placeholder{color:rgba(246,241,232,.4)}
.news-form button{background:var(--gold);color:#fff;padding:0 22px;font-weight:500;transition:.3s var(--ease)}
.news-form button:hover{background:var(--gold-soft);color:var(--ink)}
.news-ok{color:var(--gold-soft);font-size:.85rem;margin-top:10px;height:18px}
.socials{display:flex;gap:10px;margin-top:24px}
.socials a{width:40px;height:40px;border:1px solid rgba(246,241,232,.2);border-radius:50%;display:grid;place-items:center;font-family:var(--ff-en-sans);font-size:.72rem;letter-spacing:.05em;color:rgba(246,241,232,.7);transition:.3s var(--ease)}
.socials a:hover{background:var(--gold);border-color:var(--gold);color:#fff}
.foot-bottom{border-top:1px solid rgba(246,241,232,.1);padding-block:24px;display:flex;flex-wrap:wrap;justify-content:space-between;gap:14px;font-family:var(--ff-en-sans);font-size:.78rem;color:rgba(246,241,232,.45);letter-spacing:.04em}
.foot-bottom .pay{display:flex;gap:14px}

/* ---------- Mobile nav ---------- */
.mobile-nav{position:fixed;inset:0;z-index:80;background:var(--espresso);color:var(--paper);padding:90px clamp(24px,7vw,50px) 40px;transform:translateX(100%);transition:transform .5s var(--ease);display:flex;flex-direction:column;gap:6px;overflow-y:auto}
[dir="ltr"] .mobile-nav{transform:translateX(-100%)}
.mobile-nav.open{transform:none}
.mobile-nav a{font-family:var(--ff-ar-display);font-weight:600;font-size:1.6rem;padding-block:14px;border-bottom:1px solid rgba(246,241,232,.1);transition:.3s var(--ease)}
.lang-en .mobile-nav a{font-family:var(--ff-en-serif)}
.mobile-nav a:hover{color:var(--gold-soft)}
.mn-close{position:absolute;top:24px;inset-inline-end:24px;width:46px;height:46px;color:var(--paper);font-size:1.5rem}
.mn-cta{margin-top:24px}

/* ---------- Overlays ---------- */
.overlay{position:fixed;inset:0;z-index:90;background:rgba(22,17,12,.6);backdrop-filter:blur(6px);opacity:0;visibility:hidden;transition:.4s var(--ease)}
.overlay.open{opacity:1;visibility:visible}
.search-panel{position:fixed;top:0;inset-inline:0;z-index:95;background:var(--paper);transform:translateY(-100%);transition:transform .5s var(--ease);padding:40px clamp(20px,6vw,80px)}
.search-panel.open{transform:none}
.search-panel .sp-row{display:flex;align-items:center;gap:18px;max-width:var(--wrap);margin-inline:auto;border-bottom:2px solid var(--espresso);padding-bottom:16px}
.search-panel input{flex:1;border:none;outline:none;background:none;font-family:var(--ff-ar-display);font-size:clamp(1.4rem,3vw,2.2rem);color:var(--espresso)}
.search-panel input::placeholder{color:var(--sand-deep)}
.search-panel .sp-close{font-size:1.6rem;color:var(--brown)}
.sp-tags{max-width:var(--wrap);margin:22px auto 0;display:flex;flex-wrap:wrap;gap:10px}
.sp-tags span{font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.1em;color:var(--muted);text-transform:uppercase;margin-inline-end:6px}
.sp-tags a{padding:8px 16px;border:1px solid var(--line);border-radius:30px;font-size:.86rem;color:var(--brown);transition:.3s var(--ease)}
.sp-tags a:hover{background:var(--espresso);color:var(--paper);border-color:var(--espresso)}

.modal{position:fixed;z-index:100;inset:0;display:grid;place-items:center;padding:24px;opacity:0;visibility:hidden;transition:.4s var(--ease)}
.modal.open{opacity:1;visibility:visible}
.modal-box{background:var(--paper);border-radius:8px;max-width:880px;width:100%;display:grid;grid-template-columns:1fr 1fr;overflow:hidden;box-shadow:var(--shadow);transform:translateY(20px);transition:.4s var(--ease)}
.modal.open .modal-box{transform:none}
.modal-img{aspect-ratio:1/1;background:#e7ddcb}
.modal-img img{width:100%;height:100%;object-fit:cover}
.modal-info{padding:40px;position:relative}
.modal-close{position:absolute;top:18px;inset-inline-end:18px;width:40px;height:40px;border-radius:50%;background:var(--ivory);color:var(--brown);display:grid;place-items:center;font-size:1.2rem;transition:.3s var(--ease)}
.modal-close:hover{background:var(--espresso);color:var(--paper)}
.modal-info .m-cat{font-family:var(--ff-en-sans);font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold)}
.modal-info h3{font-family:var(--ff-ar-display);font-weight:700;font-size:2rem;color:var(--espresso);margin:8px 0 6px}
.lang-en .modal-info h3{font-family:var(--ff-en-serif)}
.modal-info .m-price{font-family:var(--ff-en-sans);font-size:1.5rem;color:var(--espresso);margin:14px 0}
.modal-info .m-desc{color:var(--muted);font-size:.94rem;margin-bottom:22px}
.m-opts{margin-bottom:26px}
.m-opts .lbl{font-size:.8rem;color:var(--muted);margin-bottom:10px}
.swatches{display:flex;gap:10px}
.swatch{width:30px;height:30px;border-radius:50%;border:2px solid transparent;outline:1px solid var(--line);cursor:pointer;transition:.3s var(--ease)}
.swatch.sel{border-color:var(--gold)}
.toast{position:fixed;bottom:30px;inset-inline-start:50%;transform:translate(-50%,30px);z-index:120;background:var(--espresso);color:var(--paper);padding:14px 26px;border-radius:40px;font-size:.9rem;box-shadow:var(--shadow);opacity:0;visibility:hidden;transition:.4s var(--ease);display:flex;align-items:center;gap:10px}
.toast .tdot{color:var(--gold-soft)}
.toast.show{opacity:1;visibility:visible;transform:translate(-50%,0)}

/* ---------- Responsive ---------- */
@media(max-width:1080px){
  .cat-grid{grid-template-columns:repeat(2,1fr);grid-auto-rows:280px}
  .cat:nth-child(1){grid-column:span 2;grid-row:span 1}
  .prod-grid{grid-template-columns:repeat(2,1fr)}
  .coll-grid{grid-template-columns:1fr 1fr}
  .coll:nth-child(3){grid-column:span 2;min-height:380px}
}
@media(max-width:920px){
  .menu,.cta-shop{display:none}
  .burger{display:flex}
  .sig-grid,.br-inner{grid-template-columns:1fr}
  .sig-visual{max-width:480px;margin-inline:auto}
  .foot-top{grid-template-columns:1fr 1fr}
  .foot-brand{grid-column:1/-1}
  .news{grid-column:1/-1}
  .modal-box{grid-template-columns:1fr;max-width:440px}
  .modal-img{aspect-ratio:16/10}
}
@media(max-width:620px){
  .topbar{font-size:.66rem}
  .hero-card{display:none}
  .sec-head{flex-direction:column;align-items:flex-start}
  .sec-link{align-self:flex-start}
  .cat-grid{grid-template-columns:1fr;grid-auto-rows:240px}
  .cat:nth-child(1){grid-column:span 1}
  .prod-grid{grid-template-columns:1fr 1fr;gap:14px}
  .card-body{padding:14px}
  .card-name{font-size:1.05rem}
  .card-desc{min-height:auto}
  .quick{display:none}
  .pillars{grid-template-columns:1fr}
  .coll-grid{grid-template-columns:1fr}
  .coll:nth-child(3){grid-column:span 1}
  .br-grid{grid-template-columns:1fr}
  .foot-top{grid-template-columns:1fr}
  .show-head{flex-direction:column;align-items:flex-start}
  .room{aspect-ratio:auto;min-height:340px}
  .lang-switch{display:none}
}
@media(prefers-reduced-motion:reduce){
  *{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.15s!important;scroll-behavior:auto}
  .hero-bg img{transform:none;animation:none}
}
:focus-visible{outline:2px solid var(--gold);outline-offset:3px}

/* ===== Rollc real Next shell ===== */
.scroll-shell{
  height:100vh;
  overflow-y:auto;
  overflow-x:hidden;
  direction:ltr;
  background:#F6F1E8;
  scrollbar-width:auto;
  scrollbar-color:#777777 #16110C;
}

.rollc-page{direction:rtl;min-height:100%;}
.rollc-real-page{min-height:100%;}

.scroll-shell::-webkit-scrollbar{
  width:12px;
  background:#16110C;
}

.scroll-shell::-webkit-scrollbar-track{
  background:#16110C;
}

.scroll-shell::-webkit-scrollbar-thumb{
  background:#777777;
  border-radius:999px;
  border:2px solid #16110C;
}

.scroll-shell::-webkit-scrollbar-thumb:hover{
  background:#9A9A9A;
}


/* ===== Final direction control ===== */
.rollc-page-ar,
.rollc-page-ar .rollc-real-page{
  direction: rtl;
}

.rollc-page-en,
.rollc-page-en .rollc-real-page,
.rollc-real-page.lang-en{
  direction: ltr;
}

/* ===== Mobile language switch fix ===== */
@media (max-width: 620px){
  .actions .lang-switch{
    display: inline-flex !important;
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  .actions{
    gap: 8px;
  }

  .lang-switch button{
    min-width: 34px;
    height: 34px;
    padding: 0 8px;
    font-size: 11px;
  }
}

@media (max-width: 390px){
  .actions{
    gap: 6px;
  }

  .lang-switch button{
    min-width: 30px;
    height: 30px;
    padding: 0 6px;
    font-size: 10px;
  }
}

/* ===== Topbar text color tweak ===== */
.topbar{
  color:#FFFFFF !important;
}

.topbar b{
  color:#D9A441 !important;
}

/* ===== Final topbar colors ===== */
.topbar .topbar-main,
.topbar .topbar-sep{
  color:#FFFFFF !important;
}

.topbar .topbar-highlight{color:#FFD400!important;opacity:1!important;font-weight:800!important;}

/* ===== Real luxury quick view modal ===== */
.qv-overlay{position:fixed;inset:0;z-index:90;background:rgba(22,15,8,.55);backdrop-filter:blur(8px);opacity:0;visibility:hidden;transition:.45s var(--ease)}
.qv-overlay.open{opacity:1;visibility:visible}
.qv-modal{position:fixed;inset:0;z-index:100;display:grid;place-items:center;padding:clamp(12px,3vw,40px);opacity:0;visibility:hidden;pointer-events:none;transition:.45s var(--ease)}
.qv-modal.open{opacity:1;visibility:visible;pointer-events:auto}
.qv-box{background:var(--paper);border-radius:10px;width:min(1080px,100%);max-height:92vh;overflow:hidden;display:grid;grid-template-columns:1.05fr 1fr;box-shadow:var(--shadow);border:1px solid var(--gold-line);position:relative;transform:translateY(28px) scale(.98);transition:.55s var(--ease)}
.qv-modal.open .qv-box{transform:none}
.qv-close{position:absolute;top:16px;inset-inline-end:16px;z-index:6;width:44px;height:44px;border-radius:50%;background:rgba(251,248,242,.9);backdrop-filter:blur(4px);color:var(--brown);display:grid;place-items:center;box-shadow:var(--shadow-soft);transition:.35s var(--ease)}
.qv-close:hover{background:var(--espresso);color:var(--paper);transform:rotate(90deg)}
.qv-close svg,.qv-heart svg,.qv-zoom svg,.qv-cart svg,.qv-consult svg,.qv-ico svg,.qv-spec svg{stroke:currentColor;stroke-width:1.6;fill:none}
.qv-close svg{width:18px;height:18px}
.qv-gallery{background:#ece2d0;padding:clamp(18px,2.4vw,30px);display:flex;flex-direction:column;gap:16px;position:relative}
.qv-gallery::before{content:"";position:absolute;inset:0;background:radial-gradient(120% 80% at 50% 0%,rgba(255,255,255,.35),transparent 60%);pointer-events:none}
.qv-main{position:relative;flex:1;border-radius:var(--r);overflow:hidden;background:#e0d4bf;aspect-ratio:4/4.4;box-shadow:0 24px 50px -30px rgba(42,33,26,.5)}
.qv-main img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s var(--ease)}
.qv-main:hover img{transform:scale(1.04)}
.qv-badge{position:absolute;top:16px;inset-inline-start:16px;z-index:3;background:rgba(42,33,26,.92);color:var(--gold-soft);font-family:var(--ff-en-sans);font-size:.64rem;letter-spacing:.2em;text-transform:uppercase;padding:7px 14px;border-radius:30px}
.qv-heart{position:absolute;top:14px;inset-inline-end:14px;z-index:3;width:42px;height:42px;border-radius:50%;background:rgba(251,248,242,.92);backdrop-filter:blur(4px);display:grid;place-items:center;color:var(--brown);transition:.35s var(--ease);box-shadow:var(--shadow-soft)}
.qv-heart:hover{color:var(--gold)}
.qv-heart.active{background:var(--gold);color:#fff}
.qv-heart svg{width:19px;height:19px}
.qv-heart.active svg{fill:#fff;stroke:#fff}
.qv-zoom{position:absolute;bottom:14px;inset-inline-end:14px;z-index:3;font-family:var(--ff-en-sans);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;color:var(--brown);background:rgba(251,248,242,.88);padding:8px 14px;border-radius:30px;display:flex;align-items:center;gap:7px}
.qv-zoom svg{width:13px;height:13px}
.qv-thumbs{display:flex;gap:12px}
.qv-thumb{flex:1;aspect-ratio:1/1;border-radius:var(--r);overflow:hidden;border:1px solid transparent;outline:1px solid var(--line);cursor:pointer;transition:.35s var(--ease);opacity:.78}
.qv-thumb img{width:100%;height:100%;object-fit:cover}
.qv-thumb:hover,.qv-thumb.active{opacity:1}
.qv-thumb.active{border-color:var(--gold);outline-color:var(--gold);box-shadow:0 8px 20px -12px rgba(182,138,78,.7)}
.qv-info{padding:clamp(26px,3vw,46px);overflow-y:auto;display:flex;flex-direction:column}
.qv-info::-webkit-scrollbar{width:6px}
.qv-info::-webkit-scrollbar-thumb{background:var(--sand-deep);border-radius:6px}
.qv-cat{display:flex;align-items:center;gap:14px;font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold)}
.qv-cat::before{content:"";width:30px;height:1px;background:var(--gold)}
.qv-title{font-family:var(--ff-ar-display);font-weight:700;font-size:clamp(1.8rem,3vw,2.5rem);color:var(--espresso);line-height:1.15;margin:14px 0 4px}
.lang-en .qv-title{font-family:var(--ff-en-serif);font-weight:500}
.qv-alt{font-family:var(--ff-en-serif);font-style:italic;font-size:1.05rem;color:var(--muted)}
.qv-rating{display:flex;align-items:center;gap:10px;margin-top:14px;font-size:.84rem;color:var(--muted)}
.qv-stars{display:flex;gap:2px;color:var(--gold)}
.qv-stars svg{width:15px;height:15px;fill:currentColor}
.qv-price{display:flex;align-items:baseline;gap:12px;margin:22px 0 18px;flex-wrap:wrap}
.qv-now{font-family:var(--ff-en-sans);font-weight:500;font-size:2rem;color:var(--espresso)}
.qv-now span{font-size:.95rem;color:var(--brown);margin-inline-start:4px}
.qv-old{font-family:var(--ff-en-sans);font-size:1.05rem;color:var(--muted);text-decoration:line-through}
.qv-offer{font-family:var(--ff-en-sans);font-size:.72rem;color:#7a5a2a;background:rgba(182,138,78,.16);border:1px solid var(--gold-line);padding:5px 12px;border-radius:30px}
.qv-desc{color:var(--muted);font-size:.96rem;padding-bottom:24px;border-bottom:1px solid var(--line-soft)}
.qv-opt{margin-top:24px}
.qv-opt-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;gap:16px}
.qv-opt-head span{font-family:var(--ff-ar-display);font-weight:600;font-size:1.02rem;color:var(--espresso)}
.lang-en .qv-opt-head span{font-family:var(--ff-en-serif)}
.qv-opt-head b{font-size:.88rem;color:var(--gold);font-weight:500}
.qv-colors{display:flex;gap:14px;flex-wrap:wrap}
.qv-color{display:flex;flex-direction:column;align-items:center;gap:8px}
.qv-dot{width:40px;height:40px;border-radius:50%;border:2px solid transparent;outline:1px solid var(--line);transition:.35s var(--ease);position:relative}
.qv-dot::after{content:"✓";position:absolute;inset:0;display:grid;place-items:center;color:#fff;font-size:.9rem;opacity:0;text-shadow:0 1px 2px rgba(0,0,0,.4)}
.qv-color.active .qv-dot{border-color:var(--gold);outline-color:var(--gold);transform:scale(1.05)}
.qv-color.active .qv-dot::after{opacity:1}
.qv-color small{font-size:.74rem;color:var(--muted)}
.qv-color.active small{color:var(--espresso);font-weight:500}
.qv-sizes{display:flex;gap:12px;flex-wrap:wrap}
.qv-size{padding:13px 22px;border:1px solid var(--line);border-radius:var(--r);font-size:.92rem;color:var(--brown);transition:.35s var(--ease);background:var(--paper)}
.qv-size:hover{border-color:var(--gold-line)}
.qv-size.active{background:var(--espresso);color:var(--paper);border-color:var(--espresso)}
.qv-buy{display:flex;gap:14px;margin-top:30px;align-items:stretch}
.qv-qty{display:flex;align-items:stretch;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;flex-shrink:0}
.qv-qty button{width:48px;font-size:1.3rem;color:var(--brown);transition:.3s var(--ease)}
.qv-qty button:hover{background:var(--sand);color:var(--espresso)}
.qv-qty span{width:46px;display:grid;place-items:center;font-family:var(--ff-en-sans);font-size:1.05rem;color:var(--espresso)}
.qv-cart{flex:1;background:var(--espresso);color:var(--paper);border-radius:var(--r);font-size:1rem;font-weight:500;display:flex;align-items:center;justify-content:center;gap:12px;transition:.4s var(--ease);position:relative;overflow:hidden;padding:16px}
.qv-cart::before{content:"";position:absolute;inset:0;background:var(--gold);transform:translateY(101%);transition:transform .45s var(--ease)}
.qv-cart span,.qv-cart svg{position:relative;z-index:2}
.qv-cart:hover::before{transform:translateY(0)}
.qv-cart svg{width:19px;height:19px}
.qv-consult{margin-top:14px;width:100%;border:1px solid var(--gold);color:var(--gold);border-radius:var(--r);padding:14px;font-size:.94rem;font-weight:500;display:flex;align-items:center;justify-content:center;gap:10px;transition:.4s var(--ease)}
.qv-consult:hover{background:rgba(182,138,78,.1)}
.qv-consult svg{width:17px;height:17px}
.qv-meta{display:flex;align-items:center;gap:11px;margin-top:24px;font-size:.9rem;color:var(--brown)}
.qv-ico{color:var(--gold);flex-shrink:0;display:grid;place-items:center}
.qv-ico svg{width:19px;height:19px}
.qv-stock i{width:9px;height:9px;border-radius:50%;background:#5d8a52;box-shadow:0 0 0 3px rgba(93,138,82,.18);flex-shrink:0}
.qv-stock span{color:#456b3c;font-weight:500}
.qv-specs{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:26px}
.qv-spec{background:var(--ivory);border:1px solid var(--line-soft);border-radius:var(--r);padding:14px 10px;text-align:center;transition:.35s var(--ease)}
.qv-spec:hover{border-color:var(--gold-line);transform:translateY(-3px)}
.qv-spec span{color:var(--gold);margin-bottom:8px;display:grid;place-items:center}
.qv-spec svg{width:24px;height:24px;stroke-width:1.3}
.qv-spec b{font-size:.78rem;color:var(--brown);font-weight:500;line-height:1.35}
.qv-payline{margin-top:26px;padding-top:22px;border-top:1px solid var(--line-soft);display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
.qv-payline>span{font-family:var(--ff-en-sans);font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
.qv-payline div{display:flex;gap:8px;flex-wrap:wrap}
.qv-payline b{font-family:var(--ff-en-sans);font-size:.72rem;font-weight:500;color:var(--brown);background:var(--ivory);border:1px solid var(--line);border-radius:5px;padding:7px 12px}
@media(max-width:860px){
  .qv-modal{padding:0;place-items:end center}
  .qv-box{grid-template-columns:1fr;max-height:94vh;overflow-y:auto;border-radius:16px 16px 0 0;width:100%}
  .qv-gallery{padding:16px}
  .qv-main{aspect-ratio:4/3.6}
  .qv-info{padding:24px 20px 30px}
  .qv-specs{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:420px){
  .qv-buy{flex-wrap:wrap}
  .qv-qty{width:100%;justify-content:space-between}
  .qv-payline{flex-direction:column;align-items:flex-start}
}

/* ===== Quick view scroll fix ===== */
.qv-modal{
  overflow-y:auto !important;
  align-items:flex-start !important;
  padding-block:32px !important;
}

.qv-box{
  max-height:none !important;
}

.qv-info{
  min-height:0 !important;
  overflow-y:visible !important;
}

@media(min-width:861px){
  .qv-box{
    max-height:calc(100vh - 64px) !important;
  }

  .qv-info{
    overflow-y:auto !important;
    max-height:calc(100vh - 64px) !important;
  }

  .qv-gallery{
    min-height:0 !important;
  }
}

/* ===== Quick view gallery thumbnails visibility fix ===== */
@media(min-width:861px){
  .qv-box{
    max-height:calc(100vh - 72px) !important;
  }

  .qv-gallery{
    max-height:calc(100vh - 72px) !important;
    min-height:0 !important;
    overflow-y:auto !important;
  }

  .qv-main{
    flex:0 0 auto !important;
    height:clamp(360px, calc(100vh - 220px), 540px) !important;
    aspect-ratio:auto !important;
  }

  .qv-thumbs{
    flex-shrink:0 !important;
  }

  .qv-info{
    max-height:calc(100vh - 72px) !important;
    overflow-y:auto !important;
  }
}

/* ===== Quick view single clean scroll fix ===== */
.qv-modal{
  overflow:hidden !important;
  align-items:center !important;
  padding-block:24px !important;
}

.qv-box{
  max-height:calc(100vh - 48px) !important;
  overflow:hidden !important;
}

.qv-gallery{
  max-height:none !important;
  overflow:hidden !important;
}

.qv-info{
  max-height:calc(100vh - 48px) !important;
  overflow-y:auto !important;
  scrollbar-width:none !important;
}

.qv-info::-webkit-scrollbar{
  display:none !important;
}

@media(min-width:861px){
  .qv-main{
    height:clamp(350px, calc(100vh - 230px), 520px) !important;
    aspect-ratio:auto !important;
  }

  .qv-thumbs{
    flex-shrink:0 !important;
  }
}

/* ===== Quick view dimensions row ===== */
.qv-dimensions{
  margin-top:14px;
  padding:13px 15px;
  border:1px solid var(--line-soft);
  border-radius:var(--r);
  background:rgba(246,241,232,.62);
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:14px;
}

.qv-dimensions span{
  font-family:var(--ff-ar-display);
  font-weight:600;
  color:var(--espresso);
  font-size:.92rem;
}

.lang-en .qv-dimensions span{
  font-family:var(--ff-en-serif);
}

.qv-dimensions b{
  font-family:var(--ff-en-sans);
  font-weight:500;
  color:var(--muted);
  font-size:.82rem;
  text-align:end;
}

/* ===== Quick view dimensions inline alignment fix ===== */
.qv-dimensions{
  justify-content:flex-start !important;
  align-items:center !important;
  gap:8px !important;
  text-align:start !important;
}

.qv-dimensions span{
  flex-shrink:0 !important;
}

.qv-dimensions b{
  text-align:start !important;
  flex:1 !important;
}

/* ===== Product detail page ===== */
.pdp-crumb{
  padding-block:22px;
  font-family:var(--ff-en-sans);
  font-size:.8rem;
  color:var(--muted);
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}

.pdp-crumb a{
  transition:.3s var(--ease);
}

.pdp-crumb a:hover{
  color:var(--gold);
}

.pdp-crumb span{
  color:var(--sand-deep);
}

.pdp-crumb b{
  color:var(--espresso);
  font-weight:500;
}

.pdp-hero{
  display:grid;
  grid-template-columns:1.15fr 1fr;
  gap:clamp(28px,4vw,64px);
  align-items:start;
  padding-bottom:clamp(50px,6vw,90px);
}

.pdp-gallery{
  position:sticky;
  top:96px;
  display:flex;
  flex-direction:column;
  gap:16px;
}

.pdp-main-img{
  position:relative;
  border-radius:8px;
  overflow:hidden;
  background:#ece2d0;
  aspect-ratio:4/4.2;
  box-shadow:var(--shadow-soft);
}

.pdp-main-img img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform 1.1s var(--ease);
}

.pdp-main-img:hover img{
  transform:scale(1.04);
}

.pdp-badge{
  position:absolute;
  top:18px;
  inset-inline-start:18px;
  z-index:3;
  background:rgba(42,33,26,.92);
  color:var(--gold-soft);
  font-family:var(--ff-en-sans);
  font-size:.64rem;
  letter-spacing:.2em;
  text-transform:uppercase;
  padding:7px 14px;
  border-radius:30px;
}

.pdp-save{
  position:absolute;
  top:16px;
  inset-inline-end:16px;
  z-index:3;
  width:44px;
  height:44px;
  border-radius:50%;
  background:rgba(251,248,242,.92);
  backdrop-filter:blur(4px);
  display:grid;
  place-items:center;
  color:var(--brown);
  transition:.35s var(--ease);
  box-shadow:var(--shadow-soft);
}

.pdp-save:hover{
  color:var(--gold);
}

.pdp-save.active{
  background:var(--gold);
  color:#fff;
}

.pdp-save svg{
  width:20px;
  height:20px;
  stroke:currentColor;
  stroke-width:1.5;
  fill:none;
}

.pdp-save.active svg{
  fill:#fff;
}

.pdp-thumbs{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:14px;
}

.pdp-thumbs button{
  aspect-ratio:1/1;
  border-radius:var(--r);
  overflow:hidden;
  border:1px solid transparent;
  outline:1px solid var(--line);
  transition:.35s var(--ease);
  opacity:.8;
}

.pdp-thumbs button:hover,
.pdp-thumbs button.active{
  opacity:1;
}

.pdp-thumbs button.active{
  border-color:var(--gold);
  outline-color:var(--gold);
  box-shadow:0 8px 20px -12px rgba(182,138,78,.7);
}

.pdp-thumbs img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.pdp-panel{
  position:sticky;
  top:96px;
}

.pdp-eyebrow{
  display:inline-flex;
  align-items:center;
  gap:14px;
  font-family:var(--ff-en-sans);
  font-size:.7rem;
  letter-spacing:.3em;
  text-transform:uppercase;
  color:var(--gold);
}

.pdp-eyebrow::before{
  content:"";
  width:28px;
  height:1px;
  background:var(--gold);
}

.pdp-panel h1{
  font-family:var(--ff-ar-display);
  font-weight:700;
  font-size:clamp(2rem,3.4vw,2.8rem);
  color:var(--espresso);
  line-height:1.12;
  margin:14px 0 4px;
}

.lang-en .pdp-panel h1{
  font-family:var(--ff-en-serif);
  font-weight:500;
}

.pdp-sub{
  font-family:var(--ff-en-serif);
  font-style:italic;
  font-size:1.1rem;
  color:var(--muted);
}

.pdp-rating{
  display:flex;
  align-items:center;
  gap:10px;
  margin-top:14px;
  font-size:.85rem;
  color:var(--muted);
}

.pdp-rating span{
  color:var(--gold);
  letter-spacing:.08em;
}

.pdp-rating b{
  font-weight:400;
}

.pdp-price{
  display:flex;
  align-items:baseline;
  gap:12px;
  margin:22px 0 18px;
  flex-wrap:wrap;
}

.pdp-price strong{
  font-family:var(--ff-en-sans);
  font-weight:500;
  font-size:2.1rem;
  color:var(--espresso);
}

.pdp-price small{
  font-size:.95rem;
  color:var(--brown);
  margin-inline-start:4px;
}

.pdp-price del{
  font-family:var(--ff-en-sans);
  font-size:1.05rem;
  color:var(--muted);
}

.pdp-price em{
  font-style:normal;
  font-family:var(--ff-en-sans);
  font-size:.72rem;
  color:#7a5a2a;
  background:rgba(182,138,78,.16);
  border:1px solid var(--gold-line);
  padding:6px 13px;
  border-radius:30px;
}

.pdp-desc{
  color:var(--muted);
  font-size:.98rem;
  padding-bottom:24px;
  border-bottom:1px solid var(--line-soft);
}

.pdp-options{
  margin-top:24px;
}

.pdp-options h3{
  font-family:var(--ff-ar-display);
  font-weight:600;
  font-size:1.04rem;
  color:var(--espresso);
  margin-bottom:14px;
}

.lang-en .pdp-options h3{
  font-family:var(--ff-en-serif);
}

.pdp-colors{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
}

.pdp-colors button{
  width:42px;
  height:42px;
  border-radius:50%;
  border:2px solid transparent;
  outline:1px solid var(--line);
  transition:.35s var(--ease);
}

.pdp-colors button.active{
  border-color:var(--gold);
  outline-color:var(--gold);
  transform:scale(1.06);
}

.pdp-sizes{
  display:flex;
  gap:12px;
  flex-wrap:wrap;
}

.pdp-sizes button{
  padding:13px 24px;
  border:1px solid var(--line);
  border-radius:var(--r);
  font-size:.92rem;
  color:var(--brown);
  transition:.35s var(--ease);
  background:var(--paper);
}

.pdp-sizes button:hover{
  border-color:var(--gold-line);
}

.pdp-sizes button.active{
  background:var(--espresso);
  color:var(--paper);
  border-color:var(--espresso);
}

.pdp-buy{
  display:flex;
  gap:14px;
  margin-top:30px;
  align-items:stretch;
}

.pdp-qty{
  display:flex;
  align-items:stretch;
  border:1px solid var(--line);
  border-radius:var(--r);
  overflow:hidden;
  flex-shrink:0;
}

.pdp-qty button{
  width:48px;
  font-size:1.3rem;
  color:var(--brown);
  transition:.3s var(--ease);
}

.pdp-qty button:hover{
  background:var(--sand);
  color:var(--espresso);
}

.pdp-qty span{
  width:46px;
  display:grid;
  place-items:center;
  font-family:var(--ff-en-sans);
  font-size:1.05rem;
  color:var(--espresso);
}

.pdp-cart{
  flex:1;
  background:var(--espresso);
  color:var(--paper);
  border-radius:var(--r);
  font-size:1rem;
  font-weight:500;
  padding:16px;
  transition:.4s var(--ease);
}

.pdp-cart:hover{
  background:var(--gold);
}

.pdp-consult{
  margin-top:14px;
  width:100%;
  border:1px solid var(--gold);
  color:var(--gold);
  border-radius:var(--r);
  padding:14px;
  font-size:.94rem;
  font-weight:500;
  transition:.4s var(--ease);
}

.pdp-consult:hover{
  background:rgba(182,138,78,.1);
}

.pdp-trust{
  margin-top:24px;
  padding-top:22px;
  border-top:1px solid var(--line-soft);
  display:flex;
  flex-direction:column;
  gap:12px;
  color:var(--brown);
  font-size:.9rem;
}

.pdp-trust div{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
}

.pdp-trust b{
  font-family:var(--ff-en-sans);
  font-size:.72rem;
  font-weight:500;
  color:var(--brown);
  background:var(--ivory);
  border:1px solid var(--line);
  border-radius:5px;
  padding:7px 12px;
}

.pdp-spec-strip{
  background:var(--paper);
  border-block:1px solid var(--line);
  padding-block:clamp(32px,4vw,54px);
}

.pdp-spec-grid{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:18px;
}

.pdp-spec{
  text-align:center;
  padding:18px 10px;
  border:1px solid var(--line-soft);
  border-radius:var(--r);
  color:var(--espresso);
  font-family:var(--ff-ar-display);
  font-weight:600;
  background:var(--ivory);
}

.lang-en .pdp-spec{
  font-family:var(--ff-en-serif);
}

.pdp-section{
  padding-block:clamp(56px,7vw,110px);
  position:relative;
}

.pdp-story{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:clamp(36px,5vw,80px);
  align-items:center;
}

.pdp-story h2,
.pdp-dims h2,
.pdp-centered-head h2,
.pdp-room h2,
.pdp-reviews-head h2,
.pdp-sec-head h2{
  font-family:var(--ff-ar-display);
  color:var(--espresso);
  line-height:1.18;
  font-size:clamp(1.9rem,3.4vw,2.8rem);
  margin-top:16px;
}

.lang-en .pdp-story h2,
.lang-en .pdp-dims h2,
.lang-en .pdp-centered-head h2,
.lang-en .pdp-room h2,
.lang-en .pdp-reviews-head h2,
.lang-en .pdp-sec-head h2{
  font-family:var(--ff-en-serif);
  font-weight:500;
}

.pdp-story p,
.pdp-room p{
  color:var(--muted);
  font-size:1.02rem;
  margin-top:18px;
  max-width:58ch;
}

.pdp-story blockquote{
  font-family:var(--ff-en-serif);
  font-style:italic;
  font-size:1.35rem;
  color:var(--gold);
  border-inline-start:2px solid var(--gold);
  padding-inline-start:20px;
  margin-top:26px;
  line-height:1.5;
}

.pdp-story img{
  width:100%;
  aspect-ratio:5/6;
  object-fit:cover;
  border-radius:8px;
  box-shadow:var(--shadow);
}

.pdp-dims-section,
.pdp-room-section,
.pdp-related:nth-of-type(even){
  background:var(--paper);
}

.pdp-dims{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:clamp(36px,5vw,70px);
  align-items:center;
}

.pdp-dim-list{
  margin-top:26px;
}

.pdp-dim-list div{
  display:flex;
  align-items:baseline;
  justify-content:space-between;
  padding:18px 0;
  border-bottom:1px solid var(--line-soft);
  gap:20px;
}

.pdp-dim-list span{
  font-family:var(--ff-ar-display);
  font-weight:600;
  color:var(--espresso);
}

.lang-en .pdp-dim-list span{
  font-family:var(--ff-en-serif);
}

.pdp-dim-list b{
  font-family:var(--ff-en-sans);
  color:var(--brown);
  font-weight:500;
}

.pdp-diagram{
  background:var(--ivory);
  border:1px solid var(--line);
  border-radius:8px;
  padding:clamp(26px,4vw,46px);
}

.pdp-diagram svg{
  width:100%;
  height:auto;
}

.pdp-diagram rect{
  fill:#d8c2a0;
  stroke:var(--brown);
  stroke-width:1.5;
}

.pdp-diagram line{
  stroke:var(--gold);
  stroke-width:1.4;
}

.pdp-diagram text{
  fill:var(--brown);
  font-family:var(--ff-en-sans);
  font-size:14px;
}

.pdp-centered-head{
  text-align:center;
  margin-bottom:46px;
}

.pdp-centered-head .pdp-eyebrow{
  justify-content:center;
}

.pdp-accordion{
  max-width:880px;
  margin-inline:auto;
}

.pdp-acc-item{
  border-bottom:1px solid var(--line);
}

.pdp-acc-item button{
  width:100%;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:20px;
  padding:26px 4px;
  text-align:start;
}

.pdp-acc-item button span{
  font-family:var(--ff-ar-display);
  font-weight:600;
  font-size:1.25rem;
  color:var(--espresso);
}

.lang-en .pdp-acc-item button span{
  font-family:var(--ff-en-serif);
}

.pdp-acc-item button b{
  width:34px;
  height:34px;
  border:1px solid var(--gold-line);
  border-radius:50%;
  display:grid;
  place-items:center;
  color:var(--gold);
  font-size:1.25rem;
}

.pdp-acc-item.open button span{
  color:var(--gold);
}

.pdp-acc-item.open button b{
  background:var(--gold);
  color:#fff;
  border-color:var(--gold);
}

.pdp-acc-item p{
  color:var(--muted);
  font-size:.98rem;
  padding:0 4px 28px;
  max-width:64ch;
}

.pdp-room{
  display:grid;
  grid-template-columns:1.4fr 1fr;
  gap:clamp(28px,4vw,56px);
  align-items:stretch;
}

.pdp-room-img{
  border-radius:8px;
  overflow:hidden;
  min-height:420px;
  box-shadow:var(--shadow-soft);
}

.pdp-room-img img{
  width:100%;
  height:100%;
  object-fit:cover;
}

.pdp-mini-product{
  display:flex;
  align-items:center;
  gap:16px;
  padding:14px;
  border:1px solid var(--line-soft);
  border-radius:var(--r);
  margin-top:12px;
  transition:.35s var(--ease);
  background:var(--ivory);
}

.pdp-mini-product:hover{
  border-color:var(--gold-line);
  transform:translateX(-4px);
}

.pdp-mini-product img{
  width:56px;
  height:56px;
  border-radius:var(--r);
  object-fit:cover;
  flex-shrink:0;
}

.pdp-mini-product span{
  flex:1;
  font-family:var(--ff-ar-display);
  color:var(--espresso);
  font-weight:600;
}

.lang-en .pdp-mini-product span{
  font-family:var(--ff-en-serif);
}

.pdp-mini-product b{
  font-family:var(--ff-en-sans);
  color:var(--brown);
  font-size:.9rem;
}

.pdp-reviews-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:30px;
  flex-wrap:wrap;
  margin-bottom:48px;
}

.pdp-reviews-head strong{
  font-family:var(--ff-en-serif);
  font-size:4rem;
  color:var(--espresso);
  line-height:1;
}

.pdp-review-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:22px;
}

.pdp-review-grid article{
  background:var(--paper);
  border:1px solid var(--line-soft);
  border-radius:8px;
  padding:30px;
  transition:.4s var(--ease);
}

.pdp-review-grid article:hover{
  border-color:var(--gold-line);
  box-shadow:var(--shadow-soft);
  transform:translateY(-4px);
}

.pdp-review-grid span{
  color:var(--gold);
  letter-spacing:.08em;
}

.pdp-review-grid p{
  color:var(--text);
  margin:14px 0 22px;
  line-height:1.8;
}

.pdp-review-grid b{
  color:var(--espresso);
  font-family:var(--ff-ar-display);
}

.lang-en .pdp-review-grid b{
  font-family:var(--ff-en-serif);
}

.pdp-sec-head{
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  gap:30px;
  margin-bottom:46px;
}

.pdp-sec-head a{
  font-family:var(--ff-en-sans);
  font-size:.78rem;
  letter-spacing:.14em;
  text-transform:uppercase;
  color:var(--brown);
  border-bottom:1px solid var(--gold-line);
  padding-bottom:6px;
}

.pdp-sec-head a:hover{
  color:var(--gold);
}

.pdp-product-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:22px;
}

.pdp-card{
  background:var(--ivory);
  border:1px solid var(--line);
  border-radius:8px;
  overflow:hidden;
  transition:.45s var(--ease);
  display:block;
}

.pdp-card:hover{
  transform:translateY(-6px);
  box-shadow:var(--shadow-soft);
  border-color:var(--gold-line);
}

.pdp-card>div{
  position:relative;
  aspect-ratio:1/1;
  overflow:hidden;
  background:#e7ddcb;
}

.pdp-card>div span{
  position:absolute;
  top:14px;
  inset-inline-start:14px;
  background:rgba(42,33,26,.9);
  color:var(--gold-soft);
  font-family:var(--ff-en-sans);
  font-size:.62rem;
  letter-spacing:.18em;
  text-transform:uppercase;
  padding:5px 11px;
  border-radius:30px;
  z-index:2;
}

.pdp-card img{
  width:100%;
  height:100%;
  object-fit:cover;
  transition:transform 1s var(--ease);
}

.pdp-card:hover img{
  transform:scale(1.06);
}

.pdp-card section{
  padding:20px;
}

.pdp-card small{
  font-family:var(--ff-en-sans);
  font-size:.64rem;
  letter-spacing:.2em;
  text-transform:uppercase;
  color:var(--gold);
}

.pdp-card h3{
  font-family:var(--ff-ar-display);
  font-weight:600;
  font-size:1.2rem;
  color:var(--espresso);
  margin:6px 0 10px;
}

.lang-en .pdp-card h3{
  font-family:var(--ff-en-serif);
}

.pdp-card b{
  font-family:var(--ff-en-sans);
  color:var(--espresso);
}

@media(max-width:1080px){
  .pdp-hero,
  .pdp-story,
  .pdp-dims,
  .pdp-room{
    grid-template-columns:1fr;
  }

  .pdp-gallery,
  .pdp-panel{
    position:static;
  }

  .pdp-spec-grid{
    grid-template-columns:repeat(3,1fr);
  }

  .pdp-review-grid{
    grid-template-columns:1fr;
  }

  .pdp-product-grid{
    grid-template-columns:repeat(2,1fr);
  }
}

@media(max-width:560px){
  .pdp-spec-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .pdp-sec-head,
  .pdp-reviews-head{
    flex-direction:column;
    align-items:flex-start;
  }

  .pdp-product-grid{
    grid-template-columns:1fr 1fr;
    gap:14px;
  }

  .pdp-card section{
    padding:14px;
  }

  .pdp-buy{
    flex-wrap:wrap;
  }

  .pdp-qty{
    width:100%;
    justify-content:space-between;
  }
}

