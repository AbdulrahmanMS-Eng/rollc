}


/* ===== Exact reference fonts and reveal motion ===== */
.productTemplate{
  --ff-display:var(--font-el-messiri), "El Messiri", serif;
  --ff-body:var(--font-tajawal), "Tajawal", sans-serif;
  --ff-serif:var(--font-cormorant), "Cormorant Garamond", serif;
  --ff-sans:var(--font-jost), "Jost", sans-serif;
  font-family:var(--ff-body) !important;
  line-height:1.7;
}

.crumb,
.pEyebrow,
.stars,
.priceNow,
.priceOld,
.priceSave,
.qtyValue,
.trustLabel,
.payMethods span,
.dimValue,
.diagramNote,
.sugPrice,
.revVerified,
.secLink,
.cardCat,
.cardPrice,
.brHours,
.stickyPrice{
  font-family:var(--ff-sans) !important;
}

.pTitle,
.optLabel,
.specText,
.sectionTitle,
.dimKey,
.accTitle,
.sugName,
.revName,
.revAvatar,
.cardName,
.brCity,
.stickyName{
  font-family:var(--ff-display) !important;
}

.pSub,
.storyPull,
.revBig{
  font-family:var(--ff-serif) !important;
}

:global(.lang-en) .productTemplate{
  font-family:var(--ff-sans) !important;
}

:global(.lang-en) .pTitle,
:global(.lang-en) .optLabel,
:global(.lang-en) .specText,
:global(.lang-en) .sectionTitle,
:global(.lang-en) .dimKey,
:global(.lang-en) .accTitle,
:global(.lang-en) .sugName,
:global(.lang-en) .revName,
:global(.lang-en) .cardName,
:global(.lang-en) .brCity{
  font-family:var(--ff-serif) !important;
  font-weight:500;
}

.productTemplate [data-rollc-reveal="true"]{
  opacity:0;
  transform:translateY(34px);
  transition:opacity .9s var(--ease), transform .9s var(--ease);
}

.productTemplate [data-rollc-in="true"]{
  opacity:1;
  transform:none;
}

@media(prefers-reduced-motion:reduce){
  .productTemplate [data-rollc-reveal="true"]{
    opacity:1 !important;
    transform:none !important;
    transition-duration:.15s !important;
  }
}


/* ===== Scroll reveal motion fix ===== */
:global(.rollc-pdp-reveal){
  opacity:0;
  transform:translateY(34px);
  transition:opacity .9s var(--ease), transform .9s var(--ease);
  will-change:opacity, transform;
}

:global(.rollc-pdp-reveal.rollc-pdp-reveal-in){
  opacity:1;
  transform:none;
}

@media(prefers-reduced-motion:reduce){
  :global(.rollc-pdp-reveal){
    opacity:1;
    transform:none;
    transition:none;
  }
}
