<file path="src/components/rollc/product/ProductPage.module.css">
.productTemplate{
  --line-soft:rgba(42,33,26,.07);
  --shadow:0 40px 110px -40px rgba(28,20,12,.6);
  --r:6px;
}

.productTemplate :global(.wrap){max-width:1320px}

.section{padding-block:clamp(56px,7vw,110px);position:relative}

.eyebrow{font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.4em;text-transform:uppercase;color:var(--gold);font-weight:500;display:inline-flex;align-items:center;gap:14px}
.eyebrow::before{content:"";width:32px;height:1px;background:var(--gold)}

.crumb{padding-block:22px;font-family:var(--ff-en-sans);font-size:.8rem;color:var(--muted);display:flex;align-items:center;gap:10px;flex-wrap:wrap;letter-spacing:.02em}
.crumb a{transition:.3s var(--ease)}
.crumb a:hover{color:var(--gold)}
.sep{color:var(--sand-deep)}
.nowCrumb{color:var(--espresso);font-weight:500}

.pdp{display:grid;grid-template-columns:1.15fr 1fr;gap:clamp(28px,4vw,64px);align-items:start;padding-bottom:clamp(50px,6vw,90px)}
.gallery{position:sticky;top:96px;display:flex;flex-direction:column;gap:16px}
.gMain{position:relative;border-radius:8px;overflow:hidden;background:#ece2d0;aspect-ratio:4/4.2;box-shadow:var(--shadow-soft)}
.gMain img{width:100%;height:100%;object-fit:cover;transition:opacity .5s var(--ease),transform 1.1s var(--ease)}
.gMain:hover img{transform:scale(1.04)}
.gBadge{position:absolute;top:18px;inset-inline-start:18px;z-index:3;background:rgba(42,33,26,.92);color:var(--gold-soft);font-family:var(--ff-en-sans);font-size:.64rem;letter-spacing:.2em;text-transform:uppercase;padding:7px 14px;border-radius:30px}
.gSave{position:absolute;top:16px;inset-inline-end:16px;z-index:3;width:44px;height:44px;border-radius:50%;background:rgba(251,248,242,.92);backdrop-filter:blur(4px);display:grid;place-items:center;color:var(--brown);transition:.35s var(--ease);box-shadow:var(--shadow-soft)}
.gSave:hover{color:var(--gold)}
.gSaveActive{background:var(--gold);color:#fff}
.gSave svg{width:20px;height:20px;stroke:currentColor;stroke-width:1.5;fill:none}
.gSaveActive svg{fill:#fff}
.gZoom{position:absolute;bottom:16px;inset-inline-end:16px;z-index:3;font-family:var(--ff-en-sans);font-size:.64rem;letter-spacing:.18em;text-transform:uppercase;color:var(--brown);background:rgba(251,248,242,.9);padding:9px 15px;border-radius:30px;display:flex;align-items:center;gap:7px;transition:.3s var(--ease)}
.gZoom:hover{background:var(--espresso);color:var(--paper)}
.gZoom svg{width:13px;height:13px;stroke:currentColor;stroke-width:1.6;fill:none}
.thumbs{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.thumb{aspect-ratio:1/1;border-radius:var(--r);overflow:hidden;border:1px solid transparent;outline:1px solid var(--line);cursor:pointer;transition:.35s var(--ease);opacity:.8;background:#e7ddcb}
.thumb img{width:100%;height:100%;object-fit:cover}
.thumb:hover{opacity:1}
.thumbActive{opacity:1;border-color:var(--gold);outline-color:var(--gold);box-shadow:0 8px 20px -12px rgba(182,138,78,.7)}

.panel{position:sticky;top:96px}
.pEyebrow{display:flex;align-items:center;gap:14px;font-family:var(--ff-en-sans);font-size:.7rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold)}
.pEyebrow::before{content:"";width:28px;height:1px;background:var(--gold)}
.pTitle{font-family:var(--ff-ar-display);font-weight:700;font-size:clamp(2rem,3.4vw,2.8rem);color:var(--espresso);line-height:1.12;margin:14px 0 4px}
:global(.lang-en) .pTitle{font-family:var(--ff-en-serif);font-weight:500}
.pSub{font-family:var(--ff-en-serif);font-style:italic;font-size:1.1rem;color:var(--muted)}
.pRating{display:flex;align-items:center;gap:10px;margin-top:14px;font-size:.85rem;color:var(--muted)}
.stars{display:flex;gap:2px;color:var(--gold)}
.stars svg{width:15px;height:15px;fill:currentColor}
.starsLarge svg{width:18px;height:18px}
.pPrice{display:flex;align-items:baseline;gap:12px;margin:22px 0 18px;flex-wrap:wrap}
.priceNow{font-family:var(--ff-en-sans);font-weight:500;font-size:2.1rem;color:var(--espresso)}
.currency{font-size:.95rem;color:var(--brown);margin-inline-start:4px}
.priceOld{font-family:var(--ff-en-sans);font-size:1.05rem;color:var(--muted);text-decoration:line-through}
.priceSave{font-family:var(--ff-en-sans);font-size:.72rem;letter-spacing:.05em;color:#7a5a2a;background:rgba(182,138,78,.16);border:1px solid var(--gold-line);padding:6px 13px;border-radius:30px}
.pDesc{color:var(--muted);font-size:.98rem;padding-bottom:24px;border-bottom:1px solid var(--line-soft);line-height:1.8}
.opt{margin-top:24px}
.optHead{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.optLabel{font-family:var(--ff-ar-display);font-weight:600;font-size:1.04rem;color:var(--espresso)}
:global(.lang-en) .optLabel{font-family:var(--ff-en-serif)}
.optValue{font-size:.88rem;color:var(--gold);font-weight:500}
.colors{display:flex;gap:16px;flex-wrap:wrap}
.color{display:flex;flex-direction:column;align-items:center;gap:8px;cursor:pointer}
.colorDot{width:42px;height:42px;border-radius:50%;border:2px solid transparent;outline:1px solid var(--line);transition:.35s var(--ease);position:relative}
.colorDot::after{content:"✓";position:absolute;inset:0;display:grid;place-items:center;color:#fff;font-size:.95rem;opacity:0;transition:.3s var(--ease);text-shadow:0 1px 2px rgba(0,0,0,.4)}
.colorActive .colorDot{border-color:var(--gold);outline-color:var(--gold);transform:scale(1.06)}
.colorActive .colorDot::after{opacity:1}
.colorName{font-size:.74rem;color:var(--muted);transition:.3s var(--ease)}
.colorActive .colorName{color:var(--espresso);font-weight:500}
.sizes{display:flex;gap:12px;flex-wrap:wrap}
.size{padding:13px 24px;border:1px solid var(--line);border-radius:var(--r);font-size:.92rem;color:var(--brown);transition:.35s var(--ease);background:var(--paper)}
.size:hover{border-color:var(--gold-line)}
.sizeActive{background:var(--espresso);color:var(--paper);border-color:var(--espresso)}
.buyRow{display:flex;gap:14px;margin-top:30px;align-items:stretch}
.qty{display:flex;align-items:stretch;border:1px solid var(--line);border-radius:var(--r);overflow:hidden;flex-shrink:0}
.qty button{width:48px;font-size:1.3rem;color:var(--brown);transition:.3s var(--ease)}
.qty button:hover{background:var(--sand);color:var(--espresso)}
.qtyValue{width:46px;display:grid;place-items:center;font-family:var(--ff-en-sans);font-size:1.05rem;color:var(--espresso)}
.addCart{flex:1;background:var(--espresso);color:var(--paper);border-radius:var(--r);font-size:1rem;font-weight:500;display:flex;align-items:center;justify-content:center;gap:12px;transition:.4s var(--ease);position:relative;overflow:hidden;padding:16px}
.addCart::before{content:"";position:absolute;inset:0;background:var(--gold);transform:translateY(101%);transition:transform .45s var(--ease)}
.addCart span,.addCart svg{position:relative;z-index:2}
.addCart:hover::before{transform:translateY(0)}
.addCart svg{width:19px;height:19px;stroke:currentColor;stroke-width:1.6;fill:none}
.consult{margin-top:14px;width:100%;border:1px solid var(--gold);color:var(--gold);border-radius:var(--r);padding:14px;font-size:.94rem;font-weight:500;display:flex;align-items:center;justify-content:center;gap:10px;transition:.4s var(--ease)}
.consult:hover{background:rgba(182,138,78,.1)}
.consult svg{width:17px;height:17px;stroke:currentColor;stroke-width:1.6;fill:none}
.metaLine{display:flex;align-items:center;gap:11px;margin-top:22px;font-size:.9rem;color:var(--brown)}
.metaIcon{color:var(--gold);flex-shrink:0;display:grid;place-items:center}
.metaIcon svg{width:19px;height:19px;stroke:currentColor;stroke-width:1.5;fill:none}
.stockDot{width:9px;height:9px;border-radius:50%;background:#5d8a52;box-shadow:0 0 0 3px rgba(93,138,82,.18);flex-shrink:0}
.stock b{color:#456b3c;font-weight:500}
.trust{margin-top:24px;padding-top:22px;border-top:1px solid var(--line-soft);display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap}
.trustLabel{font-family:var(--ff-en-sans);font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted)}
.payMethods{display:flex;gap:8px;flex-wrap:wrap}
.payMethods span{font-family:var(--ff-en-sans);font-size:.72rem;font-weight:500;color:var(--brown);background:var(--ivory);border:1px solid var(--line);border-radius:5px;padding:7px 12px}

.specs{background:var(--paper);border-block:1px solid var(--line)}
.specGrid{display:grid;grid-template-columns:repeat(6,1fr);gap:18px}
.spec{text-align:center;padding:10px}
.specIcon{color:var(--gold);margin-bottom:12px;display:grid;place-items:center}
.specIcon svg{width:30px;height:30px;stroke:currentColor;stroke-width:1.25;fill:none}
.specText{font-family:var(--ff-ar-display);font-weight:600;font-size:1rem;color:var(--espresso);line-height:1.3}
:global(.lang-en) .specText{font-family:var(--ff-en-serif)}

.storyGrid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,80px);align-items:center}
.storyVisual{border-radius:8px;overflow:hidden;aspect-ratio:5/6;box-shadow:var(--shadow);position:relative}
.storyVisual img{width:100%;height:100%;object-fit:cover}
.storyText .sectionTitle{font-size:clamp(2rem,3.6vw,3rem);margin:18px 0 22px}
