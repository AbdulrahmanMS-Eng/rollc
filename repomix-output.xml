      <div class="card-media">
        ${p.tag[lang]?`<span class="card-tag">${p.tag[lang]}</span>`:""}
        <button class="card-fav" aria-label="إضافة للمفضلة"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.5-7-9.5A3.8 3.8 0 0 1 12 7a3.8 3.8 0 0 1 7 3.5C19 15.5 12 20 12 20Z"/></svg></button>
