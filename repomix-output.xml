<!-- ===== Toast ===== -->
<div class="toast" id="toast"><span class="tdot">✦</span><span id="toastMsg"></span></div>

<script>
/* ---------------- Products data ---------------- */
const products = [
  {cat:{ar:"أرائك",en:"Sofas"}, name:{ar:"أريكة ميلانو",en:"Milano Sofa"}, desc:{ar:"أريكة ثلاثية بقماش مخملي ناعم.",en:"Three-seater in soft velvet upholstery."}, price:"4,250", old:"4,990", tag:{ar:"الأكثر مبيعاً",en:"Best seller"}, img:"https://images.unsplash.com/photo-1555041469-a586c61ea9bc?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"كراسي",en:"Chairs"}, name:{ar:"كرسي أوسلو",en:"Oslo Chair"}, desc:{ar:"كرسي مريح بهيكل خشب الجوز.",en:"Lounge chair on a walnut frame."}, price:"1,750", old:"", tag:{ar:"جديد",en:"New"}, img:"https://images.unsplash.com/photo-1567538096630-e0c55bd6374c?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"طاولات",en:"Tables"}, name:{ar:"طاولة نورديك",en:"Nordic Table"}, desc:{ar:"طاولة قهوة بسطح رخامي أنيق.",en:"Coffee table with a marble top."}, price:"2,900", old:"", tag:{ar:"", en:""}, img:"https://images.unsplash.com/photo-1532372320572-cda25653a26d?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"أسرّة",en:"Beds"}, name:{ar:"سرير سرين",en:"Serene Bed"}, desc:{ar:"سرير كنج منجّد بلون رملي دافئ.",en:"Upholstered king bed in warm sand."}, price:"5,600", old:"6,400", tag:{ar:"عرض",en:"Offer"}, img:"https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"أرائك",en:"Sofas"}, name:{ar:"أريكة روما",en:"Roma Sofa"}, desc:{ar:"أريكة زاوية جلدية بلمسة فاخرة.",en:"Leather corner sofa, luxe finish."}, price:"6,800", old:"", tag:{ar:"فاخر",en:"Premium"}, img:"https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"كراسي",en:"Chairs"}, name:{ar:"كرسي كوبنهاغن",en:"Copenhagen Chair"}, desc:{ar:"كرسي مكتب بتصميم اسكندنافي.",en:"Scandinavian-style accent chair."}, price:"1,450", old:"", tag:{ar:"",en:""}, img:"https://images.unsplash.com/photo-1592078615290-033ee584e267?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"طاولات",en:"Tables"}, name:{ar:"طاولة طعام أرابيسك",en:"Arabesque Dining"}, desc:{ar:"طاولة طعام لثمانية أشخاص.",en:"Dining table seating eight."}, price:"7,200", old:"", tag:{ar:"جديد",en:"New"}, img:"https://images.unsplash.com/photo-1617806118233-18e1de247200?auto=format&fit=crop&w=700&q=80"},
  {cat:{ar:"ديكور",en:"Decor"}, name:{ar:"مصباح أمبر",en:"Amber Lamp"}, desc:{ar:"مصباح أرضي بإضاءة دافئة.",en:"Floor lamp with warm glow."}, price:"890", old:"1,150", tag:{ar:"عرض",en:"Offer"}, img:"https://images.unsplash.com/photo-1513506003901-1e6a229e2d15?auto=format&fit=crop&w=700&q=80"}
];

let lang = "ar";

/* ---------------- Render products ---------------- */
const grid = document.getElementById('prodGrid');
function priceBlock(p){
  const cur = lang==="ar" ? "ر.س" : "SAR";
  return `<span class="price"><b>${p.price}</b> <span class="cur">${cur}</span>${p.old?`<span class="old">${p.old}</span>`:""}</span>`;
}
function renderProducts(){
  grid.innerHTML = products.map((p,i)=>`
    <article class="card" data-i="${i}">
      <div class="card-media">
        ${p.tag[lang]?`<span class="card-tag">${p.tag[lang]}</span>`:""}
        <button class="card-fav" aria-label="إضافة للمفضلة"><svg viewBox="0 0 24 24"><path d="M12 20s-7-4.5-7-9.5A3.8 3.8 0 0 1 12 7a3.8 3.8 0 0 1 7 3.5C19 15.5 12 20 12 20Z"/></svg></button>
        <img src="${p.img}" alt="${p.name[lang]}" loading="lazy">
        <button class="quick" data-quick="${i}">${lang==="ar"?"عرض سريع":"Quick view"}</button>
      </div>
      <div class="card-body">
        <span class="card-cat">${p.cat[lang]}</span>
        <h3 class="card-name">${p.name[lang]}</h3>
        <p class="card-desc">${p.desc[lang]}</p>
        <div class="card-foot">
          ${priceBlock(p)}
          <button class="add-cart" data-add="${i}" aria-label="${lang==="ar"?"أضف إلى السلة":"Add to cart"}"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg></button>
        </div>
      </div>
    </article>`).join('');
}
renderProducts();

/* ---------------- Cart ---------------- */
let cart = 0;
const cartCount = document.getElementById('cartCount');
function addToCart(){
  cart++;
  cartCount.textContent = cart;
  cartCount.classList.remove('pop'); void cartCount.offsetWidth; cartCount.classList.add('pop');
  showToast(lang==="ar"?"تمت الإضافة إلى السلة":"Added to your cart");
}

/* ---------------- Toast ---------------- */
const toast = document.getElementById('toast');
const toastMsg = document.getElementById('toastMsg');
let toastT;
function showToast(msg){
  toastMsg.textContent = msg;
  toast.classList.add('show');
  clearTimeout(toastT);
  toastT = setTimeout(()=>toast.classList.remove('show'), 2200);
}

/* ---------------- Quick view modal ---------------- */
const modal = document.getElementById('modal');
function openModal(i){
  const p = products[i];
  document.getElementById('mImg').src = p.img;
  document.getElementById('mImg').alt = p.name[lang];
  document.getElementById('mCat').textContent = p.cat[lang];
  document.getElementById('mName').textContent = p.name[lang];
  document.getElementById('mDesc').textContent = p.desc[lang];
  document.getElementById('mPrice').innerHTML = `${p.price} <span style="font-size:.9rem;color:var(--muted)">${lang==="ar"?"ر.س":"SAR"}</span>`;
  modal.classList.add('open');
  document.body.style.overflow='hidden';
}
function closeModal(){modal.classList.remove('open');document.body.style.overflow='';}

/* event delegation on grid */
grid.addEventListener('click', e=>{
  const add = e.target.closest('[data-add]');
  const quick = e.target.closest('[data-quick]');
  const fav = e.target.closest('.card-fav');
  if(add){addToCart();}
  if(quick){openModal(+quick.dataset.quick);}
  if(fav){fav.style.color='#B68A4E'; showToast(lang==="ar"?"أُضيف إلى المفضلة":"Added to wishlist");}
});
document.getElementById('modalClose').addEventListener('click', closeModal);
document.getElementById('mAdd').addEventListener('click', ()=>{addToCart();closeModal();});
modal.addEventListener('click', e=>{if(e.target===modal)closeModal();});

/* swatches */
document.querySelectorAll('.swatch').forEach(s=>s.addEventListener('click',()=>{
  document.querySelectorAll('.swatch').forEach(x=>x.classList.remove('sel'));
  s.classList.add('sel');
}));

document.getElementById('cartBtn').addEventListener('click', ()=>showToast(cart? (lang==="ar"?`لديك ${cart} منتج في السلة`:`${cart} item(s) in your cart`) : (lang==="ar"?"سلتك فارغة":"Your cart is empty")));

/* ---------------- Day / Night ---------------- */
const showroom = document.getElementById('showroom');
const modeSwitch = document.getElementById('modeSwitch');
const mlDay = document.getElementById('mlDay');
const mlNight = document.getElementById('mlNight');
const roomTag = document.getElementById('roomTag');
let night=false;
modeSwitch.addEventListener('click', ()=>{
  night=!night;
  showroom.classList.toggle('night', night);
  mlDay.classList.toggle('on', !night);
  mlNight.classList.toggle('on', night);
  if(night){ roomTag.setAttribute('data-ar','الإضاءة مُشعّة'); roomTag.setAttribute('data-en','Lights on'); }
  else { roomTag.setAttribute('data-ar','الإضاءة مطفأة'); roomTag.setAttribute('data-en','Lights off'); }
  roomTag.textContent = roomTag.getAttribute('data-'+lang);
});

/* ---------------- Header scroll ---------------- */
const header = document.getElementById('header');
window.addEventListener('scroll', ()=>{
  header.classList.toggle('scrolled', window.scrollY>30);
}, {passive:true});

/* ---------------- Mobile nav ---------------- */
const burger = document.getElementById('burger');
const mobileNav = document.getElementById('mobileNav');
function toggleMobile(open){
  burger.classList.toggle('open', open);
  mobileNav.classList.toggle('open', open);
  document.body.style.overflow = open?'hidden':'';
}
burger.addEventListener('click', ()=>toggleMobile(!mobileNav.classList.contains('open')));
document.getElementById('mnClose').addEventListener('click', ()=>toggleMobile(false));
mobileNav.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>toggleMobile(false)));

/* ---------------- Search ---------------- */
const searchPanel = document.getElementById('searchPanel');
const overlay = document.getElementById('overlay');
function openSearch(){searchPanel.classList.add('open');overlay.classList.add('open');setTimeout(()=>document.getElementById('searchInput').focus(),300);}
function closeSearch(){searchPanel.classList.remove('open');overlay.classList.remove('open');}
document.getElementById('searchOpen').addEventListener('click', openSearch);
document.getElementById('searchClose').addEventListener('click', closeSearch);
overlay.addEventListener('click', closeSearch);
document.addEventListener('keydown', e=>{if(e.key==='Escape'){closeSearch();closeModal();}});

/* ---------------- Newsletter ---------------- */
document.getElementById('newsBtn').addEventListener('click', ()=>{
  const email = document.getElementById('newsEmail').value.trim();
  const ok = document.getElementById('newsOk');
  if(/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)){
    ok.textContent = lang==="ar" ? "تم الاشتراك بنجاح ✦ مرحباً بك في رولك" : "Subscribed ✦ Welcome to Rollc";
    document.getElementById('newsEmail').value='';
  } else {
    ok.textContent = lang==="ar" ? "فضلاً أدخل بريداً إلكترونياً صحيحاً" : "Please enter a valid email";
  }
});

/* ---------------- Language switch ---------------- */
const langAr = document.getElementById('langAr');
const langEn = document.getElementById('langEn');
function applyText(){
  document.querySelectorAll('[data-ar]').forEach(el=>{
    const val = el.getAttribute('data-'+lang);
    if(val!==null){
      if(el.hasAttribute('data-html') || /<br|<em/.test(el.getAttribute('data-ar'))) el.innerHTML = val;
      else el.textContent = val;
    }
  });
}
function setLang(l){
  lang=l;
  document.documentElement.lang = l;
  document.documentElement.dir = "ltr"; const rtlWrap = document.querySelector(".rollc-rtl-content"); if(rtlWrap){ rtlWrap.dir = l==="ar" ? "rtl" : "ltr"; }
  document.body.classList.toggle('lang-en', l==="en");
  langAr.classList.toggle('active', l==="ar");
  langEn.classList.toggle('active', l==="en");
  document.getElementById('searchInput').placeholder = l==="ar"?"ابحث عن أريكة، طاولة، سرير…":"Search sofas, tables, beds…";
  document.getElementById('newsEmail').placeholder = l==="ar"?"بريدك الإلكتروني":"Your email";
  applyText();
  renderProducts();
}
langAr.addEventListener('click', ()=>setLang('ar'));
langEn.addEventListener('click', ()=>setLang('en'));

/* ---------------- Scroll reveal ---------------- */
